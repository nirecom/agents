# What you can do: set your own remote URL for Claude Code session sync.
# What you can't do: does NOT enable sync if the remote is unreachable.
# Format: git remote URL. Default: git@github.com:nirecom/agent-sessions.git
SESSION_SYNC_REMOTE_URL=git@github.com:YOUR_USERNAME/agent-sessions.git

# What you can do: enable Gemini-backed image generation in draw-diagram-gemini.
# What you can't do: does NOT change which diagram skill is invoked by default.
# Format: API key string. Obtain from https://aistudio.google.com/apikey.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Worktree enforcement ---

# What you can do: block edits and commits from the main worktree so work must
#   happen in a linked worktree. Set off|0|false|no|disabled to allow direct
#   main work for trivial changes.
# What you can't do: does NOT change which branch is protected (see DEFAULT_BRANCHES).
# Format: on (default) | off | 0 | false | no | disabled.
ENFORCE_WORKTREE=on

# What you can do: add extra repo roots considered "in session" for write
#   commands that modify or destroy repo content (CWD repo always included).
# What you can't do: does NOT relax the coordination-command allowlist.
# Format: semicolon-separated absolute paths (symlinks not resolved). Windows:
#   C:\git\repo-a;C:\git\repo-b. POSIX: /home/user/repo-a;/home/user/repo-b.
ENFORCE_WORKTREE_EXTRA_REPOS=

# What you can do: allow edits/commits from main for paths matching any pattern.
# What you can't do: cannot disable the built-in .worktree-backup/** exclusion.
# Format: semicolon-separated absolute-path glob patterns; ** = any segments,
#   * = any chars except path separators. Windows: C:\git\**\todo.md.
#   POSIX: /home/user/agents/docs/**/*.md.
ENFORCE_WORKTREE_EXCLUDE=

# What you can do: override default-branch detection with an explicit list of
#   branch names treated as protected.
# What you can't do: does NOT change what "protected" means (write block scope).
# Format: comma-separated branch names. Default (unset): auto-detected, falls
#   back to main. Example: DEFAULT_BRANCHES=develop,trunk,main
DEFAULT_BRANCHES=

# What you can do: auto-merge the PR after the push step (with confirmation).
# What you can't do: does NOT skip the confirmation prompt itself.
# Format: on (default) | off. When off, the PR is left for manual merge.
AUTO_MERGE_PR=on

# --- Workflow confirmation gates ---

# What you can do: skip the outline-plan approval prompt and inline preview.
# What you can't do: does NOT skip generation of the outline artifact.
# Format: on (default, fail-safe) | off | 0 | false | no | disabled.
CONFIRM_OUTLINE=on

# What you can do: skip the detail-plan approval prompt and inline preview.
# What you can't do: does NOT skip generation of the detail artifact.
# Format: on (default, fail-safe) | off | 0 | false | no | disabled.
CONFIRM_DETAIL=on

# What you can do: skip the gitignored-file copy approval inside worktree setup.
# What you can't do: does NOT auto-confirm task-name or branch-type selection.
# Format: on (default) | off | 0 | false | no | disabled.
CONFIRM_WORKTREE=on

# What you can do: skip the planned test-cases approval prompt.
# What you can't do: does NOT bypass test-write permission dialogs.
# Format: on (default) | off | 0 | false | no | disabled.
CONFIRM_TESTS=on

# What you can do: skip the planned-edits approval prompt and auto-continue.
# What you can't do: does NOT skip lint/typecheck loop or bypass edit dialogs.
# Format: on (default) | off | 0 | false | no | disabled.
CONFIRM_CODE=on

# What you can do: require confirmation before auto-appending companion-issue
#   candidates (surfaced by workflow-init and clarify-intent) to closes_issues.
# What you can't do: does NOT change the search algorithm or candidate cap.
# Format: on (default, requires confirmation) | off (auto-appends silently).
CONFIRM_COMPANION_ISSUES=on

# What you can do: skip the docs-update approval prompt (gather, propose, apply).
# What you can't do: does NOT suppress proposed bullets from appearing in chat.
# Format: on (default) | off | 0 | false | no | disabled.
CONFIRM_DOCS=on

# What you can do: opt out of editor workspace-targeted file-open for plan
#   artifacts even when confirmation gates are on. Set to 1 to suppress.
# What you can't do: does NOT suppress inline diff preview or approval prompts.
# Format: 1 = opt out; unset or empty = default (open enabled when editor detected).
SHOW_PLAN_LINK_NO_AUTO_OPEN=

# What you can do: relocate session planning artifacts to any absolute path.
# What you can't do: does NOT enable a fallback search path; tilde is NOT expanded.
# Format: absolute filesystem path. Default (unset): ~/.workflow-plans.
#   Windows: C:\Users\<user>\.workflow-plans. POSIX: /home/<user>/.workflow-plans.
WORKFLOW_PLANS_DIR=

# What you can do: change the base directory under which parallel-session
#   worktrees are created.
# What you can't do: does NOT change per-worktree naming (task-name/<repo>).
# Format: absolute path. Default: ~/git/worktrees.
#   Windows example: WORKTREE_BASE_DIR=C:\git\worktrees
WORKTREE_BASE_DIR=

# What you can do: set the minimum age (in days) before sweep skills treat
#   session artifacts and no-PR branches as reclaim candidates.
# What you can't do: cannot configure each sweep target independently (shared);
#   does NOT affect the merged-branch min-age-hours gate.
# Format: positive integer (days). 0 and non-integers are rejected. Default: 30.
SWEEP_AGE_DAYS=30

# --- WIP state tracking ---

# What you can do: identify the GraphQL project node used for WIP signaling.
# What you can't do: does NOT replace branch/worktree isolation.
# Format: GraphQL node ID string.
WIP_STATE_STATUS_FIELD_ID=

# What you can do: identify the Status option representing "Todo".
# What you can't do: does NOT change which sessions update the status.
# Format: GraphQL option ID string.
WIP_STATE_TODO_OPTION_ID=

# What you can do: identify the Status option representing "In Progress".
# What you can't do: does NOT change which sessions update the status.
# Format: GraphQL option ID string.
WIP_STATE_IN_PROGRESS_OPTION_ID=

# What you can do: identify the Status option representing "Done".
# What you can't do: does NOT change which sessions update the status.
# Format: GraphQL option ID string.
WIP_STATE_DONE_OPTION_ID=

# What you can do: identify the text field that stores the session fingerprint.
# What you can't do: does NOT control the fingerprint value itself.
# Format: GraphQL field ID string.
WIP_STATE_FINGERPRINT_FIELD_ID=

# --- Language policy ---

# What you can do: pick the language enforced for docs/history.md and the
#   History Notes section in public repos.
# What you can't do: does NOT affect CHANGELOG.md (see DOCS_LANG_CHANGELOG_*).
# Format: english / japanese (strict, blocks on mismatch) | any (off) |
#   other tokens such as french (advisory hint only).
DOCS_LANG_HISTORY_PUBLIC=english

# What you can do: pick the language enforced for docs/history.md in private repos.
# What you can't do: does NOT affect CHANGELOG.md.
# Format: english / japanese (strict, blocks on mismatch) | any (off) |
#   other tokens such as french (advisory hint only).
DOCS_LANG_HISTORY_PRIVATE=english

# What you can do: pick the language enforced for CHANGELOG.md in public repos.
# What you can't do: does NOT affect docs/history.md.
# Format: english / japanese (strict) | any (off) | other tokens (advisory).
DOCS_LANG_CHANGELOG_PUBLIC=english

# What you can do: pick the language enforced for CHANGELOG.md in private repos.
# What you can't do: does NOT affect docs/history.md.
# Format: english / japanese (strict) | any (off) | other tokens (advisory).
DOCS_LANG_CHANGELOG_PRIVATE=any

# What you can do: pick the language enforced for session planning artifacts.
# What you can't do: does NOT affect drafts or conversation text.
# Format: english / japanese (strict, blocks on violation) | any (off) |
#   other tokens (advisory hint only).
PLAN_LANG=any

# What you can do: pick the language Claude replies in throughout the session.
# What you can't do: cannot change AskUserQuestion dialog language; does NOT
#   override PLAN_LANG or DOCS_LANG_* for written artifacts.
# Format: lowercase language name (e.g. japanese, french, traditional-chinese).
#   Set to english or leave unset to disable injection.
CONV_LANG=japanese

# What you can do: add file extensions checked by the code-size review tool.
# What you can't do: does NOT affect skill-size review (SKILL.md scope only).
# Format: bare extensions without leading dot, semicolon-separated.
#   Default: js;sh;py. Example: CODE_FILE_EXTENSIONS=js;sh;py;tf;java;ts
CODE_FILE_EXTENSIONS=

# --- MCP servers ---

# What you can do: change the timeout for the codex CLI used in adversarial
#   code review. Increase for large diffs; decrease to fail fast.
# What you can't do: does NOT affect plan-review codex invocations.
# Format: integer seconds. Default: 300.
CODEX_TIMEOUT_SECS=

# What you can do: disable the MCP filesystem server used by the codex reviewer
#   during plan review by setting the value to off.
# What you can't do: does NOT affect other MCP servers or codex behavior.
# Format: off to disable; any other value (or unset) means enabled.
CODEX_MCP_FS=

# What you can do: enable debug logging from the MCP filesystem server.
# What you can't do: does NOT affect which files are served or blocked.
# Format: 1 to enable; unset or any other value means disabled.
MCP_FS_DEBUG=
