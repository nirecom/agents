# Remote URL for Claude Code session sync.
# Copy this file to .env and set your own repository URL.
# If unset, defaults to git@github.com:nirecom/agent-sessions.git
SESSION_SYNC_REMOTE_URL=git@github.com:YOUR_USERNAME/agent-sessions.git

# Gemini API key for image generation (draw-diagram-gemini).
# Obtain from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Enforce worktree-based parallel session workflow.
# When on (default), main worktree edits and commits are blocked — work must
# happen in a linked worktree (see /worktree-start). Eliminates race-on-default-branch
# when multiple agent sessions run concurrently.
# Set to off|0|false|no|disabled for trivial direct-main work (typos, lock-file-only).
ENFORCE_WORKTREE=on

# Override default branch detection (optional). Comma-separated list of branch
# names treated as protected (in place of auto-detection).
# Default (when unset): auto-detected from git symbolic-ref refs/remotes/origin/HEAD,
# then checked for known names (main, master), then git config init.defaultBranch.
# Falls back to "main" if none resolve. Set explicitly when using develop, trunk, etc.
# DEFAULT_BRANCHES=develop,trunk,main
DEFAULT_BRANCHES=

# Auto-merge PR after /commit-push or /worktree-end (with confirmation prompt).
# off: PR is created but merge is left to the user (GitHub UI or manual).
AUTO_MERGE_PR=on

# CONFIRM_OUTLINE — gate the outline plan approval prompt (#486/#291).
# What you can do: 'off' = skip AskUserQuestion, suppress inline diff preview, and skip VS Code file-open.
# What you can't do: does NOT skip generation of <session-id>-outline.md; breadcrumb always emits.
# Format: on (default, fail-safe) | off | 0 | false | no | disabled
CONFIRM_OUTLINE=on

# CONFIRM_DETAIL — gate the detail plan approval prompt (#486/#291).
# What you can do: 'off' = skip AskUserQuestion, suppress inline diff preview, and skip VS Code file-open.
# What you can't do: does NOT skip generation of <session-id>-detail.md; breadcrumb always emits.
# Format: on (default, fail-safe) | off | 0 | false | no | disabled
CONFIRM_DETAIL=on

# CONFIRM_WORKTREE - gate the gitignored-file copy approval inside /worktree-start (step 9).
# What you can't do: does NOT auto-confirm task-name/branch-type (step 2 - not configurable).
# Same format.
CONFIRM_WORKTREE=on

# CONFIRM_TESTS - gate the /write-tests planned-cases approval prompt. Same format.
CONFIRM_TESTS=on

# CONFIRM_CODE - gate the /write-code planned-edits approval prompt.
# What you can do: set 'off' to skip AskUserQuestion and auto-continue to editing.
# What you can't do: does NOT skip lint/typecheck loop or bypass Edit permission dialogs.
# Format: on (default) | off|0|false|no|disabled. Same as CONFIRM_TESTS.
CONFIRM_CODE=on

# What you can do: skip the /update-docs approval prompt (gather → propose → apply without waiting).
# What you can't: suppress the proposed history/changelog bullets from appearing in the conversation.
# Format: on (default) | off | 0 | false | no | disabled
CONFIRM_DOCS=on

# SHOW_PLAN_LINK_NO_AUTO_OPEN — opt out of VS Code workspace-targeted file-open
# for plan artifacts, even when CONFIRM_*=on and a VS Code session is detected.
# What you can do: set to 1 to suppress the auto-open entirely.
#   Breadcrumb ("Plan file written: ...") still emits regardless.
# What you can't do: does NOT suppress inline diff preview or AskUserQuestion.
# Format: 1 = opt out; unset or empty = default (open enabled when VS Code detected).
# Example: SHOW_PLAN_LINK_NO_AUTO_OPEN=1
SHOW_PLAN_LINK_NO_AUTO_OPEN=

# Base directory for parallel-session worktrees (used by /worktree-start).
# Default: ~/git/worktrees (assumes ~/git/<repo> repo layout — sibling to your repos,
# NOT under any repo's .git directory). Override if you keep repos elsewhere.
# Windows example: WORKTREE_BASE_DIR=C:\git\worktrees
WORKTREE_BASE_DIR=

# Semicolon-separated list of additional repo roots considered "in session" for
# gh write commands that modify repo content or are destructive (gh pr merge,
# gh issue delete, gh repo delete, gh release create/edit/delete/upload,
# gh api -X|--method POST/PUT/PATCH/DELETE).
# The CWD repo is always included automatically.
# Coordination commands (gh pr create/edit/close/comment/review,
# gh issue create/edit/close/comment, gh repo create/edit/rename/archive)
# are always allowed regardless of this list.
# Use the native absolute path of your platform; symlinks are not resolved.
# Note: separator changed from ',' to ';' in 2026-05 — existing comma-separated
# values silently break and must be re-quoted with ';'.
# Windows example: ENFORCE_WORKTREE_EXTRA_REPOS=C:\git\repo-a;C:\git\repo-b
# POSIX example:   ENFORCE_WORKTREE_EXTRA_REPOS=/home/user/repo-a;/home/user/repo-b
ENFORCE_WORKTREE_EXTRA_REPOS=

# Semicolon-separated absolute-path glob patterns. Paths matching any pattern
# can be edited and committed directly from main without going through a
# worktree. Use for low-risk paths (docs, todo lists, etc.) where the
# worktree workflow is overkill.
#
# Limits:
#   - All staged files in a commit must match. Even one non-matching file
#     blocks the commit.
#   - Other safety checks (secret protection, outbound data inspection,
#     etc.) still apply independently.
#
# Pattern syntax: ** = any number of path segments, * = any chars except
# path separators. ? and {a,b} are not supported. Case-insensitive on
# Windows, case-sensitive elsewhere.
# Windows example: ENFORCE_WORKTREE_EXCLUDE=C:\git\**\todo.md
# POSIX example:   ENFORCE_WORKTREE_EXCLUDE=/home/user/agents/docs/**/*.md
ENFORCE_WORKTREE_EXCLUDE=

# What you can do: relocate session planning artifacts (intent/outline/detail .md)
#   to any absolute path outside ~/.workflow-plans/.
# What you can't do: does NOT enable a fallback to ~/.claude/plans/ — one path is
#   authoritative. Tilde (~) is NOT expanded. Relative paths are rejected at startup.
# Format: absolute filesystem path.
#   Windows example: WORKFLOW_PLANS_DIR=C:\Users\<user>\.workflow-plans
#   POSIX example:   WORKFLOW_PLANS_DIR=/home/<user>/.workflow-plans
# Default (when unset): ~/.workflow-plans
# Resolved at runtime by hooks/lib/workflow-plans-dir.js and bin/workflow-plans-dir;
# consumed by JS hooks directly and by skill prompts via the orchestrator-injects
# protocol (skills/_shared/resolve-plans-dir.md).
WORKFLOW_PLANS_DIR=

# WIP signaling via GitHub Projects v2 Status field (issue #362).
# Run `bash bin/github-issues/wip-state.sh setup` once to discover and persist
# the IDs below from your project. After that, /workflow-init and /clarify-intent
# call wip-state.sh set/check/clear to surface which session is actively working
# an issue (visible in the Projects board across machines).
#
# What you can do: enable cross-session WIP signaling per issue.
# What you can't do: this does NOT replace branch/worktree isolation — it only
#   surfaces "session X is working issue #N" in the Projects v2 UI.
# Format: GraphQL node IDs as returned by `gh api graphql` (string).
#   Status field is a single-select with options Todo / In Progress / Done.
#   session-fingerprint is a text field on the same project.
WIP_STATE_STATUS_FIELD_ID=
WIP_STATE_TODO_OPTION_ID=
WIP_STATE_IN_PROGRESS_OPTION_ID=
WIP_STATE_DONE_OPTION_ID=
WIP_STATE_FINGERPRINT_FIELD_ID=

# --- Language policy (.env keys replace the legacy docs-lang fenced block in rules/language.md) ---

# DOCS_LANG_HISTORY_PUBLIC — language for docs/history.md and ## History Notes in
#   WORKTREE_NOTES.md (public repos).
# What you can do:
#   - "english" / "japanese": strict enforcement (CJK / English-run heuristic, blocks
#     on mismatch).
#   - "any": disables enforcement.
#   - Any other value (e.g. "french", "de-DE", "zh-CN"): advisory hint only — the
#     model is told which language to use, but content is not blocked.
# What you can't do: does NOT affect CHANGELOG.md (see DOCS_LANG_CHANGELOG_*).
#   Enforced by hooks/check-worktree-notes-lang.js (PostToolUse on ## History Notes
#   in WORKTREE_NOTES.md) and bin/compose-doc-append-entry.
# Format: single token (no spaces). If both .env and the docs-lang block in
#   rules/language.md are set, .env wins.
DOCS_LANG_HISTORY_PUBLIC=english

# DOCS_LANG_HISTORY_PRIVATE — language for docs/history.md and ## History Notes
#   (private repos). Same value space as DOCS_LANG_HISTORY_PUBLIC.
DOCS_LANG_HISTORY_PRIVATE=english

# DOCS_LANG_CHANGELOG_PUBLIC — language for CHANGELOG.md in public repos.
# What you can do:
#   - "english" / "japanese": strict enforcement (CJK / English-run heuristic, blocks
#     on mismatch).
#   - "any": disables enforcement.
#   - Any other value: advisory hint only — content is not blocked.
DOCS_LANG_CHANGELOG_PUBLIC=english

# DOCS_LANG_CHANGELOG_PRIVATE — language for CHANGELOG.md in private repos.
# Same value space as DOCS_LANG_CHANGELOG_PUBLIC (strict for english/japanese,
# any disables, other values are advisory hints).
DOCS_LANG_CHANGELOG_PRIVATE=any

# PLAN_LANG — language for planning artifacts (<session>-intent/outline/detail.md).
# What you can do:
#   - "english" / "japanese": strict enforcement (blocks on violation) via
#     hooks/check-plan-lang.js (PostToolUse).
#   - "any": disables enforcement.
#   - Any other value: advisory hint only — the model is told which language to use,
#     but the write is approved regardless of content language.
# Does NOT affect drafts/ files or conversation text.
PLAN_LANG=any

# CONV_LANG — preferred language for main conversation text. Prompt-only (no hook enforcement).
CONV_LANG=japanese

# CODE_FILE_EXTENSIONS — semicolon-separated file extensions for review-code-size.
# What you can do: add extensions for additional languages (tf, java, ts, dart, go, etc.).
# What you can't do: does NOT affect review-skill-size (SKILL.md scope only).
# Format: bare extensions without leading dot, semicolon-separated. Default: js;sh;py
# Example: CODE_FILE_EXTENSIONS=js;sh;py;tf;java;ts
CODE_FILE_EXTENSIONS=

# ---------------------------------------------------------------------------
# MCP servers
# ---------------------------------------------------------------------------

# CODEX_MCP_FS — enable/disable the MCP filesystem server for codex reviewer.
# What you can do: set to "off" to disable the repo-scoped file-read tool that
#   the codex reviewer uses during plan review.
# What you can't do: does NOT affect other MCP servers or codex behavior.
# Format: "off" to disable; any other value (or unset) means enabled.
# Example: CODEX_MCP_FS=off
CODEX_MCP_FS=

# MCP_FS_DEBUG — enable debug logging for the MCP filesystem server.
# What you can do: set to "1" to write [mcp-fs] lines to stderr for each
#   deny/serve event. When LOG_DIR is also set in your shell, review-plan-codex
#   saves the MCP server's stderr to $LOG_DIR/detail-plan-codex-stderr.log.
# What you can't do: does NOT affect which files are served or blocked.
# Format: "1" to enable; unset or any other value means disabled.
# Example: MCP_FS_DEBUG=1
MCP_FS_DEBUG=
