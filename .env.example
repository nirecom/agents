# Remote URL for Claude Code session sync.
# Copy this file to .env and set your own repository URL.
# If unset, defaults to git@github.com:nirecom/agent-sessions.git
SESSION_SYNC_REMOTE_URL=git@github.com:YOUR_USERNAME/agent-sessions.git

# Gemini API key for image generation (draw-diagram-gemini).
# Obtain from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Auto-branch policy. When ON (default), Claude is blocked from editing or
# committing on the default branch (main/master) — must use a feature branch
# or worktree. Eliminates race-on-default-branch when multiple agent sessions
# are running. Set to off|0|false|no|disabled to allow direct main work.
AGENT_AUTO_BRANCH=on

# Override default branch detection (optional). Comma-separated list of branch
# names treated as protected (in place of main/master auto-detection).
# Useful for repos using `develop` or `trunk` as the integration branch.
# AGENT_DEFAULT_BRANCHES=develop,trunk,main
