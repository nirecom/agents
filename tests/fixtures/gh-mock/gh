#!/bin/bash
# Mock gh CLI for issue-migration tests.
# Dispatches based on argument patterns and GH_MOCK_SCENARIO env var.

SCENARIO="${GH_MOCK_SCENARIO:-default}"

# Join all args for matching
ARGS="$*"

# ----------------------------------------------------------------------------
# Shared dispatch for `gh --jq` invocations introduced by issue #222 refactor.
# The real gh CLI accepts `--jq EXPR` and applies it to the JSON response
# server-side. The mock hardcodes the per-scenario output for known patterns.
# Handled here (before the per-scenario `case`) so every scenario shares it.
# ----------------------------------------------------------------------------

# Helper: emit the bare state string for `--json state --jq .state`.
mock_state_for_scenario() {
  case "$SCENARIO" in
    issue_task|issue_incident|issue_no_labels|open_with_pending|open_with_appended|open_with_stale_pending|open_with_malformed_created_at|open_with_future_created_at|meta_admin_close_path|meta_child_open|meta_zero_children|meta_no_repo)
      echo "OPEN" ;;
    closed_no_sentinel|closed_no_sentinel_open_subissue|closed_with_appended_sentinel|closed_with_resolved_comment|closed_with_both|closed_with_pending|closed_with_merged_sentinel|closed_with_stale_pending|closed_multi_reference)
      echo "CLOSED" ;;
    *)
      echo "OPEN" ;;
  esac
}

# Helper: emit the FIRST sentinel comment body matching the given prefix
# (`appended`, `pending`, or `any` for the broader `^<!-- issue-close-sentinel:`).
# Empty string when no match — same as `first // ""` in real jq.
mock_sentinel_for_scenario() {
  local kind="$1"   # appended | appended_with_newline_prefix | any
  case "$SCENARIO" in
    closed_with_appended_sentinel|closed_with_both|open_with_appended)
      # Both `any` and `appended` (with or without "m" flag) match — sentinel
      # is on line 1 here, so regex anchored to start-of-string also hits.
      echo "<!-- issue-close-sentinel: appended (resolved-by: closes-keyword) -->"
      ;;
    closed_with_merged_sentinel)
      # Merged format: sentinel sits on LINE 2 of the comment body. The
      # (^|\n) prefix in the jq regex matches line-starts inside a string,
      # so the lookup succeeds only when has_appended_sentinel() uses (^|\n).
      if [ "$kind" = "appended_with_newline_prefix" ] || [ "$kind" = "any" ]; then
        echo "<!-- issue-close-sentinel: appended (resolved-by: backfill-history-introducer, commit=abc1234) -->"
      fi
      # `appended` lookup (no (^|\n) prefix) → empty: simulates that without
      # the prefix, a line-2 sentinel is invisible to the idempotency check.
      ;;
    open_with_pending|closed_with_pending|open_with_stale_pending|closed_with_stale_pending|open_with_malformed_created_at|open_with_future_created_at)
      if [ "$kind" = "any" ]; then
        echo "<!-- issue-close-sentinel: pending -->"
      fi
      # `appended` lookup → empty
      ;;
    *)
      : # empty
      ;;
  esac
}

# Helper: emit the resolved-by comment for the given hash, when present.
mock_resolved_by_for_scenario() {
  local hash="$1"
  case "$SCENARIO" in
    closed_with_resolved_comment|closed_with_both|closed_with_merged_sentinel)
      if [ "$hash" = "abc1234" ]; then
        echo "<!-- resolved-by: abc1234 -->"
      fi
      ;;
    *)
      : # empty
      ;;
  esac
}

# Cross-scenario dispatch: any --jq invocation we recognize is handled here.
case "$ARGS" in
  "issue view "*" --json state --jq"*)
    mock_state_for_scenario
    exit 0
    ;;
  # Meta-cascade label query: scripts inspect the `meta` label to decide
  # whether to route an OPEN issue through admin_close_path.
  "issue view "*" --json labels --jq"*)
    case "${GH_MOCK_SCENARIO:-}" in
      meta_admin_close_path|meta_child_open|meta_zero_children|meta_no_repo)
        echo "true"
        ;;
      *)
        echo "false"
        ;;
    esac
    exit 0
    ;;
  # Repo slug lookup: the meta-cascade probe needs OWNER/REPO to call
  # parent-all-closed-check.sh; meta_no_repo simulates the failure case.
  "repo view --json nameWithOwner --jq .nameWithOwner"*)
    case "${GH_MOCK_SCENARIO:-}" in
      meta_no_repo)
        echo "gh: repo not found" >&2
        exit 1
        ;;
      *)
        echo "owner/repo"
        exit 0
        ;;
    esac
    ;;
  "issue view "*" --json comments --jq"*"resolved-by: "*)
    # Extract hash from `resolved-by: <hash> -->` inside the --jq expression.
    HASH=$(printf '%s' "$ARGS" | sed -nE 's/.*resolved-by: ([0-9a-f]+) -->.*/\1/p')
    mock_resolved_by_for_scenario "$HASH"
    exit 0
    ;;
  # validate_sentinel_freshness: returns ISO8601 createdAt of the sentinel comment.
  # Must match BEFORE the generic "issue-close-sentinel:" sentinel-body dispatch
  # because the new jq expression contains both ".createdAt" and the marker substring.
  "issue view "*" --json comments --jq"*".createdAt"*)
    case "${GH_MOCK_SCENARIO:-}" in
        open_with_stale_pending|closed_with_stale_pending)
            # 35 days ago (stale relative to default 30-day threshold)
            node -e 'console.log(new Date(Date.now()-35*86400000).toISOString())' 2>/dev/null || \
                echo "2020-01-01T00:00:00Z"
            ;;
        open_with_malformed_created_at)
            echo "not-a-date"
            ;;
        open_with_future_created_at)
            # 30 days in the future
            node -e 'console.log(new Date(Date.now()+30*86400000).toISOString())' 2>/dev/null || \
                echo "2099-12-31T00:00:00Z"
            ;;
        open_with_pending|open_with_appended|closed_with_pending|closed_with_appended_sentinel|*)
            # fresh (3 days ago)
            node -e 'console.log(new Date(Date.now()-3*86400000).toISOString())' 2>/dev/null || \
                date -u +%Y-%m-%dT%H:%M:%SZ
            ;;
    esac
    exit 0
    ;;
  "issue view "*" --json comments --jq"*"issue-close-sentinel: appended"*)
    if [[ "$ARGS" == *'(^|\\n)'* ]]; then
        mock_sentinel_for_scenario appended_with_newline_prefix
    else
        mock_sentinel_for_scenario appended
    fi
    exit 0
    ;;
  "issue view "*" --json comments --jq"*"issue-close-sentinel:"*)
    mock_sentinel_for_scenario any
    exit 0
    ;;
  # Global `gh issue comment <N> --body <text>` handler.
  # All scenarios share this: append body to $GH_MOCK_COMMENT_LOG (if set)
  # with a `---COMMENT---` separator so tests can count calls.
  "issue comment "*" --body "*)
    if [ -n "${GH_MOCK_COMMENT_LOG:-}" ]; then
        BODY="${ARGS#*--body }"
        printf '%s\n---COMMENT---\n' "$BODY" >> "$GH_MOCK_COMMENT_LOG"
    fi
    exit 0
    ;;
  "issue list --state closed"*"--limit"*"--jq"*".[].number"*)
    # Allow override via GH_MOCK_ISSUE_NUMBERS (newline-separated).
    # NOTE: gh issue list does NOT support --paginate (unlike gh api).
    # The script uses --limit 1000 instead. Mock pattern matches accordingly.
    if [ "${GH_MOCK_SCENARIO:-}" = "canary_six_class" ]; then
        printf '%s\n' 101 102 103 104 105 106 107 108 109 110 111 112
        exit 0
    fi
    if [ -n "${GH_MOCK_ISSUE_NUMBERS:-}" ]; then
        printf '%s\n' "$GH_MOCK_ISSUE_NUMBERS"
    else
        echo "42"
    fi
    exit 0
    ;;
  # find-pr-by-marker.sh primary: marker-based PR search (issue-close-pr-of:N in PR body).
  # GH_MOCK_MARKER_PR_RESULT controls output (tab-separated number\tsha), empty = no match.
  "pr list"*"issue-close-pr-of:"*"--state merged"*"--jq"*)
    if [ -n "${GH_MOCK_MARKER_PR_RESULT:-}" ]; then
        printf '%s\n' "$GH_MOCK_MARKER_PR_RESULT"
    fi
    exit 0
    ;;
  # find-pr-by-marker.sh fallback step 2: pr view N --json mergeCommit --jq .mergeCommit.oid
  "pr view "*" --json mergeCommit --jq"*)
    PR_N=$(printf '%s' "$ARGS" | sed -nE 's/.*pr view ([0-9]+) .*/\1/p')
    var="GH_MOCK_PR_MERGE_SHA_FOR_${PR_N}"
    val="${!var:-}"
    [ -n "$val" ] && printf '%s' "$val"
    exit 0
    ;;
  # closedByPullRequestsReferences dispatch — two callers with different --jq shapes:
  #   find-pr-by-marker.sh wants .closedByPullRequestsReferences[0].number  (contains ".number")
  #   backfill-commit-comments.sh (Tier 0a) wants mergeCommit.oid           (does not contain ".number")
  "issue view "*" --json closedByPullRequestsReferences --jq"*)
    N=$(printf '%s' "$ARGS" | sed -nE 's/.*issue view ([0-9]+) .*/\1/p')
    if [[ "$ARGS" == *".number"* ]]; then
        # find-pr-by-marker.sh: new primary jq returns "<number>\t<sha>".
        var="GH_MOCK_CLOSED_BY_PR_NUM_FOR_${N}"
        if [ -n "${!var+x}" ] && [ -n "${!var}" ]; then
            PR_N="${!var}"
            sha_var="GH_MOCK_PR_MERGE_SHA_FOR_${PR_N}"
            SHA="${!sha_var:-}"
            printf '%s\t%s\n' "$PR_N" "$SHA"
            exit 0
        fi
        # Handle closed_multi_reference scenario specially: two PRs in
        # closedByPullRequestsReferences (PR 100 older, PR 200 newer).
        # sort_by(.mergedAt) | last → PR 200.
        case "${GH_MOCK_SCENARIO:-}" in
            closed_multi_reference)
                printf '%s\t%s\n' "200" "newsha200"
                exit 0
                ;;
        esac
        # No match → empty result.
        exit 0
    else
        # backfill-commit-comments.sh (Tier 0a): wants mergeCommit.oid
        var="GH_MOCK_PR_MERGE_COMMIT_FOR_${N}"
        if [ -n "${!var+x}" ]; then
            val="${!var}"
            if [ -n "$val" ]; then
                printf '%s' "$val"
            fi
            exit 0
        fi
    fi
    ;;
  # Tier 0b: body dispatch (per-issue env var override)
  "issue view "*" --json body --jq"*)
    N=$(printf '%s' "$ARGS" | sed -nE 's/.*issue view ([0-9]+) .*/\1/p')
    var="GH_MOCK_BODY_FOR_${N}"
    if [ -n "${!var+x}" ]; then
        printf '%s' "${!var}"
        exit 0
    fi
    ;;
  # Tier 1.5: title dispatch (per-issue env var override)
  "issue view "*" --json title --jq"*)
    N=$(printf '%s' "$ARGS" | sed -nE 's/.*issue view ([0-9]+) .*/\1/p')
    var="GH_MOCK_TITLE_FOR_${N}"
    if [ -n "${!var+x}" ]; then
        printf '%s' "${!var}"
        exit 0
    fi
    ;;
  # Issue list dispatch: canary_six_class scenario returns 12 issues
  "issue list --state closed "*"--json number --jq"*)
    case "${GH_MOCK_SCENARIO:-}" in
      canary_six_class)
          printf '%s\n' 101 102 103 104 105 106 107 108 109 110 111 112
          exit 0
          ;;
    esac
    ;;
  # Label list handler — used by sync-labels.sh three-way status (issue #724).
  # Emits GH_MOCK_LABEL_LIST (TSV: name\tcolor\tdescription per line) verbatim.
  # Empty/unset GH_MOCK_LABEL_LIST = empty set (no existing labels remotely).
  # Set GH_MOCK_LABEL_LIST_FAIL=1 to simulate API failure (exit 1 with stderr).
  "label list --json name,color,description --limit 1000 --jq"*)
    if [ "${GH_MOCK_LABEL_LIST_FAIL:-0}" = "1" ]; then
        echo "gh: label list API error" >&2
        exit 1
    fi
    if [ -n "${GH_MOCK_LABEL_LIST:-}" ]; then
        printf '%s\n' "$GH_MOCK_LABEL_LIST"
    fi
    exit 0
    ;;
  # Label create handler — used by sync-labels.sh / bootstrap-labels.sh.
  # Logs the full args to $GH_MOCK_LABEL_LOG (if set) and exits 0.
  "label create "*"--force"*)
    if [ -n "${GH_MOCK_LABEL_LOG:-}" ]; then
        printf '%s\n' "$ARGS" >> "$GH_MOCK_LABEL_LOG"
    fi
    exit 0
    ;;
  # Non-force label create handler (issue #724 three-way status):
  # fires when the more-specific --force pattern above did NOT match.
  # Same logging behavior; exit 0.
  "label create "*)
    if [ -n "${GH_MOCK_LABEL_LOG:-}" ]; then
        printf '%s\n' "$ARGS" >> "$GH_MOCK_LABEL_LOG"
    fi
    exit 0
    ;;
esac

case "$SCENARIO" in
  issue_task)
    case "$ARGS" in
      "issue view 42 --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Test task issue","body":"Background: test\nChanges: did stuff","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue view "*" --json state,comments")
        echo '{"state":"OPEN","comments":[]}'
        exit 0
        ;;
    esac
    ;;
  issue_incident)
    case "$ARGS" in
      "issue view 42 --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Outage","body":"Cause: bug\nFix: patched","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:incident"}]}'
        exit 0
        ;;
    esac
    ;;
  issue_no_labels)
    case "$ARGS" in
      "issue view 42 --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Plain issue","body":"Background: x\nChanges: y","closedAt":"2026-05-10T00:00:00Z","labels":[]}'
        exit 0
        ;;
    esac
    ;;
  issue_view_fail)
    case "$ARGS" in
      "issue view "*)
        echo "gh: not found" >&2
        exit 1
        ;;
    esac
    ;;
  no_subissues)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  all_closed_subissues)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  one_open_subissue)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        # Count of open
        if [[ "$ARGS" == *'select(.state=="open")'*'length'* ]]; then
          echo "1"
        else
          # Detail listing
          echo '[{"number":11,"title":"Open child","state":"open"}]'
        fi
        exit 0
        ;;
    esac
    ;;
  three_open_subissues)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        if [[ "$ARGS" == *'length'* && "$ARGS" != *"map"* ]]; then
          echo "3"
        else
          echo '[{"number":11,"title":"A","state":"open"},{"number":12,"title":"B","state":"open"},{"number":13,"title":"C","state":"open"}]'
        fi
        exit 0
        ;;
    esac
    ;;
  paginated_one_open)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        echo "1"
        exit 0
        ;;
    esac
    ;;
  paginated_all_closed)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  all_cancelled_or_migrated)
    case "$ARGS" in
      "api repos/owner/repo/issues/10/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  api_fail)
    case "$ARGS" in
      "api "*)
        echo "gh: API error" >&2
        exit 1
        ;;
    esac
    ;;
  # --- Issue #222 scenarios: CLOSED-state + resolved-by-commit comments -----
  # `gh issue comment <N> --body <text>` is supported across all scenarios in
  # this block: it appends the body to $GH_MOCK_COMMENT_LOG (if set) and
  # exits 0. Used to verify that the skill / backfill script posts the
  # expected sentinel and resolved-by comments.
  closed_no_sentinel)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json comments"*)
        echo '[]'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Closed-by-keyword task","body":"Background: closed via PR\nChanges: feature shipped","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        # If --jq '.[].number' is part of the call, return raw numbers one per
        # line (mimics real gh's jq passthrough). Otherwise emit a JSON list.
        if [[ "$ARGS" == *"--jq"* ]]; then
          echo "42"
        else
          echo '[{"number":42,"title":"Closed-by-keyword task","closedAt":"2026-05-10T00:00:00Z"}]'
        fi
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
      "api repos/"*"/issues/"*" --jq .parent.number"*)
        # No parent — emit empty.
        exit 0
        ;;
    esac
    ;;
  closed_no_sentinel_open_subissue)
    # Trap scenario for FT5b. Sub-issue count=1; if auto_close_path ever
    # re-schedules Step B, gate exits non-zero here.
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json comments"*)
        echo '[]'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Closed-by-keyword task","body":"Background: closed via PR\nChanges: feature shipped","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        if [[ "$ARGS" == *"--jq"* ]]; then
          echo "42"
        else
          echo '[{"number":42,"title":"Closed-by-keyword task","closedAt":"2026-05-10T00:00:00Z"}]'
        fi
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "1"
        exit 0
        ;;
      "api repos/"*"/issues/"*" --jq .parent.number"*)
        exit 0
        ;;
    esac
    ;;
  closed_with_appended_sentinel)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[{"body":"<!-- issue-close-sentinel: appended (resolved-by: closes-keyword) -->"}]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json comments"*)
        echo '[{"body":"<!-- issue-close-sentinel: appended (resolved-by: closes-keyword) -->"}]'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Already appended","body":"Background: x\nChanges: y","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        if [[ "$ARGS" == *"--jq"* ]]; then
          echo "42"
        else
          echo '[{"number":42,"title":"Already appended","closedAt":"2026-05-10T00:00:00Z"}]'
        fi
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  closed_with_resolved_comment)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[{"body":"<!-- resolved-by: abc1234 -->\nResolved by commit `abc1234`."}]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Resolved-by present","body":"Background: x\nChanges: y","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        echo '[{"number":42,"title":"Resolved-by present","closedAt":"2026-05-10T00:00:00Z"}]'
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  closed_with_both)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[{"body":"<!-- resolved-by: abc1234 -->\nResolved by commit `abc1234`."},{"body":"<!-- issue-close-sentinel: appended (resolved-by: closes-keyword) -->"}]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Both present","body":"Background: x\nChanges: y","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        echo '[{"number":42,"title":"Both present","closedAt":"2026-05-10T00:00:00Z"}]'
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
    esac
    ;;
  closed_with_merged_sentinel)
    # Merged J-1+J-2 format: a single comment whose body has the
    # resolved-by marker on line 1, the appended sentinel on line 2,
    # and the visible "Resolved by commit ..." line on line 3.
    # Idempotency requires has_appended_sentinel() to use the "m" flag.
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[{"body":"<!-- resolved-by: abc1234 -->\n<!-- issue-close-sentinel: appended (resolved-by: backfill-history-introducer, commit=abc1234) -->\nResolved by commit `abc1234`."}]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"CLOSED"}'
        exit 0
        ;;
      "issue view "*" --json comments"*)
        echo '[{"body":"<!-- resolved-by: abc1234 -->\n<!-- issue-close-sentinel: appended (resolved-by: backfill-history-introducer, commit=abc1234) -->\nResolved by commit `abc1234`."}]'
        exit 0
        ;;
      "issue view "*" --json number,title,body,closedAt,labels")
        echo '{"number":42,"title":"Merged sentinel present","body":"Background: x\nChanges: y","closedAt":"2026-05-10T00:00:00Z","labels":[{"name":"type:task"}]}'
        exit 0
        ;;
      "issue list --state closed"*)
        if [[ "$ARGS" == *"--jq"* ]]; then
          echo "42"
        else
          echo '[{"number":42,"title":"Merged sentinel present","closedAt":"2026-05-10T00:00:00Z"}]'
        fi
        exit 0
        ;;
      "api repos/"*"/issues/"*"/sub_issues --paginate --jq"*)
        echo "0"
        exit 0
        ;;
      "api repos/"*"/issues/"*" --jq .parent.number"*)
        exit 0
        ;;
    esac
    ;;
  open_with_pending)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"OPEN","comments":[{"body":"<!-- issue-close-sentinel: pending -->"}]}'
        exit 0
        ;;
    esac
    ;;
  open_with_appended)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"OPEN","comments":[{"body":"<!-- issue-close-sentinel: appended (resolved-by: closes-keyword) -->"}]}'
        exit 0
        ;;
    esac
    ;;
  closed_with_pending)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"CLOSED","comments":[{"body":"<!-- issue-close-sentinel: pending -->"}]}'
        exit 0
        ;;
    esac
    ;;
  open_with_stale_pending)
    case "$ARGS" in
      "issue view "*" --json state,comments")
        echo '{"state":"OPEN","comments":[{"body":"<!-- issue-close-sentinel: pending -->","createdAt":"2020-01-01T00:00:00Z"}]}'
        exit 0
        ;;
      "issue view "*" --json state")
        echo '{"state":"OPEN"}'
        exit 0
