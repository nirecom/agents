#!/bin/bash
# Minimal git mock for backfill-commit-comments.sh tests.
# Recognized: git [-C <path>] log --all --oneline -E --grep=<pattern>
ARGS="$*"
case "$ARGS" in
  *"log --all"*"--reverse"*"-S"*"-- docs/history.md"*)
    # Tier 1.5: argv capture for R18/R19/R22 assertions.
    : "${GIT_MOCK_ARGV_LOG:=${TMPDIR:-/tmp}/git-mock-argv.log}"
    printf '%s\n' "$ARGS" >> "$GIT_MOCK_ARGV_LOG"
    # Per-issue slug dispatch via title-derived slug (separator-based extraction).
    needle=$(printf '%s' "$ARGS" | sed -nE 's/.*-S (.+) -- docs\/history.*/\1/p')
    needle=$(printf '%s' "$needle" | sed -E 's/[[:space:]]+$//')
    slug=$(printf '%s' "$needle" | tr -c 'a-zA-Z0-9' '_' | tr 'A-Z' 'a-z')
    var="GIT_MOCK_LOG_S_RESULT_${slug}"
    val="${!var:-${GIT_MOCK_LOG_S_RESULT:-}}"
    [ -n "$val" ] && printf '%s\n' "$val"
    exit 0
    ;;
  *"log --all --oneline"*)
    N=$(printf '%s' "$ARGS" | grep -oE '#[0-9]+' | head -n 1 | tr -d '#')
    [ -z "$N" ] && exit 0
    var="GIT_MOCK_LOG_FOR_${N}"
    val="${!var:-}"
    [ -n "$val" ] && printf '%s Closes #%s\n' "$val" "$N"
    exit 0
    ;;
  *"log --oneline HEAD"*"-- docs/history"*)
    # check_history_entry reachability check in issue-close-triage-lib.sh.
    # Returns a fake commit mentioning issue #N if GIT_MOCK_HISTORY_COMMIT_N is set.
    if [ -n "${GIT_MOCK_HISTORY_COMMIT_N:-}" ]; then
        printf 'abc1234 docs(history): record issue #%s\n' "$GIT_MOCK_HISTORY_COMMIT_N"
    fi
    exit 0
    ;;
  *"show --unified=0"*"--pretty=format:"*"-- docs/history"*)
    # Tier 1.5 bulk-import detection (issue #344).
    # The backfill script's is_bulk_history_commit() invokes:
    #   git show --unified=0 --pretty=format: -m <hash> -- docs/history.md
    # to count the number of "+### Heading" lines introduced by a commit.
    # GIT_MOCK_SHOW_HEADINGS_FOR_<hash>=<N> controls how many heading lines
    # this mock emits. The script's threshold default is 3 — at-or-above is
    # treated as bulk-import and rejected; below is accepted.
    hash=$(printf '%s' "$ARGS" | grep -oE '[0-9a-f]{7,40}' | head -n 1)
    : "${GIT_MOCK_ARGV_LOG:=${TMPDIR:-/tmp}/git-mock-argv.log}"
    printf '%s\n' "$ARGS" >> "$GIT_MOCK_ARGV_LOG"
    var="GIT_MOCK_SHOW_HEADINGS_FOR_${hash}"
    n="${!var:-0}"
    i=0
    while [ "$i" -lt "$n" ]; do
      printf '+### Heading %d\n' "$i"
      i=$((i + 1))
    done
    exit 0
    ;;
esac
# Unknown git subcommands: exit silently.
# IMPORTANT: Do NOT forward to real git — this script IS git on PATH (infinite recursion).
exit 0
