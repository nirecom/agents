#!/bin/bash
# commit-msg hook: scan commit message for private information
# Skips scanning for private repos (detected dynamically via GitHub API)

set -euo pipefail

_cfg_dir="$(cd "$(dirname "$0")/.." && pwd)"
SCANNER="$_cfg_dir/bin/scan-outbound.sh"

# Check if this repo is private via GitHub API (skip scanning if private)
REMOTE_URL="$(git remote get-url origin 2>/dev/null || true)"
if [ -n "$REMOTE_URL" ]; then
    # Extract hostname — non-GitHub hosts are treated as private (skip scanning)
    REMOTE_HOST="$(echo "$REMOTE_URL" | sed -E 's#^(ssh|https?)://([^@]+@)?([^/:]+).*#\3#' | sed -E 's#^[^@]+@([^:]+):.*#\1#')"
    if [ -n "$REMOTE_HOST" ] && [ "$REMOTE_HOST" != "github.com" ]; then
        exit 0
    fi
    REPO_ID="$(echo "$REMOTE_URL" | sed 's/\.git$//' | sed -E 's#.*[:/]([^/]+/[^/]+)$#\1#')"
    if [ -n "$REPO_ID" ] && command -v gh >/dev/null 2>&1; then
        IS_PRIVATE="$(gh api "repos/$REPO_ID" --jq .private 2>/dev/null || true)"
        if [ "$IS_PRIVATE" = "true" ]; then
            exit 0
        fi
    fi
fi

# $1 is the commit message file.
# IMPORTANT: capture rc with `|| rc=$?` — under `set -euo pipefail` the
# assignment would otherwise abort the hook on non-zero scanner exit.
SCAN_OUT=""
rc=0
SCAN_OUT="$("$SCANNER" --stdin "commit-msg" < "$1" 2>&1)" || rc=$?
case "$rc" in
    0)
        exit 0
        ;;
    1)
        printf '%s\n' "$SCAN_OUT"
        echo ""
        echo "Commit blocked: private information detected in commit message."
        echo "Fix the message, or add exceptions to .private-info-allowlist"
        exit 1
        ;;
    2)
        printf '%s\n' "$SCAN_OUT"
        echo ""
        if { : <>/dev/tty; } 2>/dev/null; then
            printf "Possible private info in message. Proceed with commit? [y/N] " > /dev/tty
            REPLY=""
            read -r REPLY < /dev/tty || REPLY=""
            case "$REPLY" in
                y|Y|yes|YES) echo "commit-msg: warn-only confirmed by user"; exit 0 ;;
                *) echo "commit-msg: aborted by user"; exit 1 ;;
            esac
        else
            echo "Commit blocked: warn-only patterns in message (no TTY available — auto-blocked)."
            echo "Re-run interactively or add an exception to .private-info-allowlist."
            exit 1
        fi
        ;;
    3)
        echo "commit-msg: scanner usage error (rc=3)" >&2
        exit 1
        ;;
    *)
        echo "commit-msg: scanner unexpected rc=$rc" >&2
        exit 1
        ;;
esac
