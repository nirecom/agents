#!/bin/bash
# Pre-commit hook: scan staged files for private information
# Skips scanning for private repos (detected dynamically via GitHub API)

set -euo pipefail

_cfg_dir="$(cd "$(dirname "$0")/.." && pwd)"
SCANNER="$_cfg_dir/bin/scan-outbound.sh"

# Load $AGENTS_CONFIG_DIR/.env (existing env wins). Mirrors hooks/lib/load-env.js.
_load_env_file() {
    local envfile="${AGENTS_CONFIG_DIR:-$_cfg_dir}/.env"
    [ -r "$envfile" ] || return 0
    local line key val
    while IFS= read -r line || [ -n "$line" ]; do
        # Skip blank and comment lines
        case "$line" in ''|\#*) continue ;; esac
        # Match KEY=VAL (KEY: alphanumeric + underscore, must start with letter/underscore)
        if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=[[:space:]]*(.*)$ ]]; then
            key="${BASH_REMATCH[1]}"
            val="${BASH_REMATCH[2]}"
            # Strip optional surrounding quotes
            case "$val" in
                \"*\") val="${val#\"}"; val="${val%\"}" ;;
                \'*\') val="${val#\'}"; val="${val%\'}" ;;
            esac
            # Set only if not already in env (preserves explicit shell exports)
            if ! printenv "$key" >/dev/null 2>&1; then
                export "$key"="$val"
            fi
        fi
    done < "$envfile"
}
_load_env_file

# ENFORCE_WORKTREE defense-in-depth: block commit from main worktree or on default branch.
# Mirrors hooks/enforce-worktree.js logic. Bash-side because git hooks run outside Node.
_is_enforce_worktree_on() {
    local v
    if printenv ENFORCE_WORKTREE >/dev/null 2>&1; then
        v="$(printf %s "${ENFORCE_WORKTREE}" | tr '[:upper:]' '[:lower:]')"
    else
        v=""
    fi
    case "$v" in
        off|0|false|no|disabled) return 1 ;;
        *) return 0 ;;
    esac
}

if _is_enforce_worktree_on; then
    # ENFORCE_WORKTREE_EXCLUDE: when ALL staged files match the exclude patterns,
    # skip the main-checkout and protected-branch gate below. The private-info
    # scanner further down still runs. Patterns and paths are passed via env
    # (never as shell-interpolated args) to prevent metacharacter injection.
    _enforce_skip=0
    _staged="$(git diff --cached --name-only 2>/dev/null || true)"
    _repo_top="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -n "$_staged" ] && [ -n "$_repo_top" ]; then
        _node_rc=0
        ENFORCE_WORKTREE_EXCLUDE="${ENFORCE_WORKTREE_EXCLUDE:-}" \
        AGENTS_CONFIG_DIR="${AGENTS_CONFIG_DIR:-$_cfg_dir}" \
        _PRECOMMIT_REPO_TOP="$_repo_top" \
        _PRECOMMIT_STAGED="$_staged" \
        node -e '
          const cfg = process.env.AGENTS_CONFIG_DIR;
          if (!cfg) process.exit(2);
          const { getExcludePatterns, isExcluded } =
            require(cfg + "/hooks/enforce-worktree/shared-cmd-utils");
          const patterns = getExcludePatterns();
          const files = process.env._PRECOMMIT_STAGED.split(/\r?\n/).filter(Boolean);
          if (patterns.length === 0) process.exit(2);
          for (const rel of files) {
            if (!isExcluded(rel, patterns)) process.exit(2);
          }
          process.exit(0);
        ' 2>/dev/null || _node_rc=$?
        if [ "$_node_rc" = "0" ]; then
            _enforce_skip=1
        elif [ "$_node_rc" != "2" ]; then
            # rc=2 is the documented "patterns did not all match" path.
            # Other non-zero rc indicates a problem (missing node, broken
            # glob-match.js, etc.). Surface it so users know their EXCLUDE
            # config was silently bypassed by an error, not by the gate.
            echo "pre-commit: ENFORCE_WORKTREE_EXCLUDE matcher failed (rc=$_node_rc); falling back to enforce-worktree gate." >&2
        fi
    fi

    # WORKFLOW_OFF / WORKTREE_OFF session-marker bypass: mirror enforce-worktree.js.
    # Resolves session id via hooks/lib/workflow-state.js#resolveSessionId() and
    # checks both .workflow-off and .worktree-off markers via hooks/lib/session-markers.js.
    # rc=0 → bypass granted; rc=2 → no bypass (sid unresolved OR no marker); any
    # other rc → unexpected error, surface a warning and fall through to enforcement.
    if [ "$_enforce_skip" = "0" ]; then
        _node_rc=0
        AGENTS_CONFIG_DIR="${AGENTS_CONFIG_DIR:-$_cfg_dir}" \
        node -e '
          try {
            const cfg = process.env.AGENTS_CONFIG_DIR;
            if (!cfg) process.exit(2);
            const { resolveSessionId } = require(cfg + "/hooks/lib/workflow-state");
            const { isWorkflowOff, isWorktreeOff } = require(cfg + "/hooks/lib/session-markers");
            const sid = resolveSessionId();
            if (!sid) process.exit(2);
            if (isWorkflowOff(sid) || isWorktreeOff(sid)) process.exit(0);
            process.exit(2);
          } catch (_e) {
            process.exit(3);
          }
        ' 2>/dev/null || _node_rc=$?
        if [ "$_node_rc" = "0" ]; then
            _enforce_skip=1
        elif [ "$_node_rc" != "2" ]; then
            echo "pre-commit: session-marker bypass check failed (rc=$_node_rc); falling back to enforce-worktree gate." >&2
        fi
    fi

    if [ "$_enforce_skip" = "0" ]; then
        # Block commits from main worktree (--git-common-dir == --git-dir)
        _git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
        _git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
        # Resolve to absolute paths before comparing (handles relative paths, symlinks,
        # and case differences on case-insensitive filesystems such as macOS/Windows).
        _git_common_dir_abs="$(cd "$_git_common_dir" 2>/dev/null && pwd -P || printf '%s' "$_git_common_dir" | tr '[:upper:]' '[:lower:]')"
        _git_dir_abs="$(cd "$_git_dir" 2>/dev/null && pwd -P || printf '%s' "$_git_dir" | tr '[:upper:]' '[:lower:]')"
        if [ -n "$_git_common_dir_abs" ] && [ -n "$_git_dir_abs" ] && [ "$_git_common_dir_abs" = "$_git_dir_abs" ]; then
            echo "ENFORCE_WORKTREE: commits from main worktree are blocked." >&2
            echo "Work from a linked worktree. Run: /worktree-start <task-name>" >&2
            echo "Or set ENFORCE_WORKTREE=off in agents config to allow direct main work." >&2
            exit 1
        fi

        cur_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
        if [ -n "$cur_branch" ]; then
            # Build protected branches list
            protected=""
            _default_branches_var="${DEFAULT_BRANCHES:-}"
            if [ -n "$_default_branches_var" ]; then
                protected="$(printf %s "$_default_branches_var" | tr ',' ' ')"
            else
                origin_head="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#.*/##' || true)"
                [ -n "$origin_head" ] && protected="$protected $origin_head"
                for cand in main master; do
                    git show-ref --verify --quiet "refs/heads/$cand" 2>/dev/null && protected="$protected $cand"
                done
                init_default="$(git config init.defaultBranch 2>/dev/null || true)"
                [ -n "$init_default" ] && protected="$protected $init_default"
                [ -z "$(printf %s "$protected" | tr -d ' ')" ] && protected="main"
            fi
            for b in $protected; do
                if [ "$cur_branch" = "$b" ]; then
                    echo "ENFORCE_WORKTREE: commits to protected branch '$cur_branch' are blocked." >&2
                    echo "Switch to a feature branch. Run: git switch -c feature/<name>" >&2
                    echo "Or set ENFORCE_WORKTREE=off in agents config to disable." >&2
                    exit 1
                fi
            done
        fi
    fi
fi

# Auto-unstage settings.json if the only change is effortLevel
SETTINGS="settings.json"
if git diff --cached --name-only | grep -qx "$SETTINGS"; then
    # Compare HEAD vs staged after stripping effortLevel from both
    STRIP_EFFORT='let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>{const j=JSON.parse(d);delete j.effortLevel;console.log(JSON.stringify(j))})'
    HEAD_CLEAN="$(git show "HEAD:$SETTINGS" 2>/dev/null | node -e "$STRIP_EFFORT" 2>/dev/null || true)"
    STAGED_CLEAN="$(git show ":$SETTINGS" 2>/dev/null | node -e "$STRIP_EFFORT" 2>/dev/null || true)"
    if [ -n "$HEAD_CLEAN" ] && [ "$HEAD_CLEAN" = "$STAGED_CLEAN" ]; then
        git reset HEAD -- "$SETTINGS" >/dev/null 2>&1
        echo "pre-commit: auto-unstaged $SETTINGS (effortLevel-only change)"
    fi
fi

# Check execute permission on staged .sh files
SH_NO_EXEC=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    mode=$(git ls-files -s "$f" | awk '{print $1}')
    if [ "$mode" = "100644" ]; then
        SH_NO_EXEC="$SH_NO_EXEC\n  $f"
    fi
done <<< "$(git diff --cached --name-only -- '*.sh')"
if [ -n "$SH_NO_EXEC" ]; then
    echo "pre-commit: .sh files lacking execute permission:$SH_NO_EXEC"
    echo "Run: git update-index --chmod=+x <file>"
    exit 1
fi

# Check if this repo is private via GitHub API (skip scanning if private)
REMOTE_URL="$(git remote get-url origin 2>/dev/null || true)"
if [ -n "$REMOTE_URL" ]; then
    # Extract hostname — non-GitHub hosts are treated as private (skip scanning)
    REMOTE_HOST="$(echo "$REMOTE_URL" | sed -E 's#^(ssh|https?)://([^@]+@)?([^/:]+).*#\3#' | sed -E 's#^[^@]+@([^:]+):.*#\1#')"
    if [ -n "$REMOTE_HOST" ] && [ "$REMOTE_HOST" != "github.com" ]; then
        exit 0
    fi
    REPO_ID="$(echo "$REMOTE_URL" | sed 's/\.git$//' | sed -E 's#.*[:/]([^/]+/[^/]+)$#\1#')"
    if [ -n "$REPO_ID" ] && command -v gh >/dev/null 2>&1; then
        IS_PRIVATE="$(gh api "repos/$REPO_ID" --jq .private 2>/dev/null || true)"
        if [ "$IS_PRIVATE" = "true" ]; then
            exit 0
        fi
    fi
fi

# Block direct commits of .env files (use .env.example / .env.sample / .env.template instead)
ENV_FILES="$(git diff --cached --name-only --diff-filter=A | grep -E '(^|/)\.env$' || true)"
if [ -n "$ENV_FILES" ]; then
    echo "pre-commit: .env file(s) staged for commit:"
    echo "$ENV_FILES" | sed 's/^/  /'
    echo "Use .env.example / .env.sample / .env.template instead."
    exit 1
fi

# Get staged files (added, copied, modified)
STAGED_FILES="$(git diff-index --cached --name-only --diff-filter=ACM HEAD 2>/dev/null || true)"
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Files to skip
SKIP_PATTERNS="bin/scan-outbound.sh|\.private-info-allowlist|\.offensive-content-blocklist\.example"

HARD_HITS=0
WARN_HITS=0
HARD_OUT=""
WARN_OUT=""

while IFS= read -r file; do
    # Skip scanner-related files
    if echo "$file" | grep -qE "$SKIP_PATTERNS"; then
        continue
    fi

    # Skip binary files
    if git show ":$file" 2>/dev/null | file --mime - 2>/dev/null | grep -q "binary"; then
        continue
    fi

    # Scan staged content. IMPORTANT: capture rc with `|| rc=$?` — under
    # `set -euo pipefail` the assignment would otherwise abort the hook on
    # non-zero scanner exit before the case below could branch.
    SCAN_OUT=""
    rc=0
    SCAN_OUT="$(git show ":$file" 2>/dev/null | "$SCANNER" --stdin "$file" 2>&1)" || rc=$?
    case "$rc" in
        0) : ;;
        1) HARD_HITS=$((HARD_HITS + 1)); HARD_OUT="$HARD_OUT"$'\n'"$SCAN_OUT" ;;
        2) WARN_HITS=$((WARN_HITS + 1)); WARN_OUT="$WARN_OUT"$'\n'"$SCAN_OUT" ;;
        3) echo "pre-commit: scanner usage error (rc=3)" >&2; exit 1 ;;
        *) echo "pre-commit: scanner unexpected rc=$rc" >&2; exit 1 ;;
    esac
done <<< "$STAGED_FILES"

# Hard wins: any hard violation blocks immediately.
if [ "$HARD_HITS" -gt 0 ]; then
    [ -n "$HARD_OUT" ] && printf '%s\n' "$HARD_OUT"
    [ -n "$WARN_OUT" ] && printf '%s\n' "$WARN_OUT"
    echo ""
    echo "Commit blocked: private information detected in staged files."
    echo "Fix the issues above, or add exceptions to .private-info-allowlist"
    exit 1
fi

# Warn-only path: re-display matches, then prompt or auto-block.
if [ "$WARN_HITS" -gt 0 ]; then
    printf '%s\n' "$WARN_OUT"
    echo ""
    if { : <>/dev/tty; } 2>/dev/null; then
        printf "Possible private info above. Proceed with commit? [y/N] " > /dev/tty
        REPLY=""
        read -r REPLY < /dev/tty || REPLY=""
        case "$REPLY" in
            y|Y|yes|YES) echo "pre-commit: warn-only confirmed by user"; exit 0 ;;
            *) echo "pre-commit: aborted by user"; exit 1 ;;
        esac
    else
        echo "Commit blocked: warn-only patterns detected (no TTY available — auto-blocked)."
        echo "Re-run interactively or add an exception to .private-info-allowlist."
        exit 1
    fi
fi
exit 0
