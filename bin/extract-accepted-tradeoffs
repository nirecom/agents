#!/usr/bin/env bash
# Extract the body of the '## Accepted Tradeoffs' section from a markdown file.
# Works against any .md (intent.md, outline.md, or similar).
# Usage: extract-accepted-tradeoffs <file>
# Exit 0 on success (even if section is absent — outputs nothing).
# Exit 2 if file not found.
set -uo pipefail

f="${1:-}"
[[ -n "$f" && -f "$f" ]] || { echo "extract-accepted-tradeoffs: file not found: ${f:-<none>}" >&2; exit 2; }

awk '
  BEGIN { inside=0 }
  /^## Accepted Tradeoffs[[:space:]]*$/ { inside=1; next }
  inside && /^## / { inside=0 }
  inside { print }
' "$f"
