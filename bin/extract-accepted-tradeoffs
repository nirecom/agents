#!/usr/bin/env bash
# Thin wrapper: extracts the body of '## Accepted Tradeoffs' from a markdown file.
# Usage: extract-accepted-tradeoffs <file>
# Delegates to extract-mandatory-sections (body-only mode for backward compatibility).
set -uo pipefail

# --- BEGIN temporary: extract-accepted-tradeoffs → extract-mandatory-sections migration ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/extract-mandatory-sections" "${1:?extract-accepted-tradeoffs: file argument required}" \
  --section "Accepted Tradeoffs"
# --- END temporary: extract-accepted-tradeoffs → extract-mandatory-sections migration ---
