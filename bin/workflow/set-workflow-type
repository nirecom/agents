#!/usr/bin/env node
"use strict";

const path = require("path");
const { readState, createInitialState, writeState } = require(
  path.join(__dirname, "../../hooks/lib/workflow-state")
);

const VALID_TYPES = new Set(["wf-code", "wf-plan"]);

const [sessionId, type] = process.argv.slice(2);

if (!sessionId || !type) {
  process.stderr.write("Usage: set-workflow-type <session-id> <type>\n");
  process.exit(1);
}

if (!/^[A-Za-z0-9_-]+$/.test(sessionId)) {
  process.stderr.write(`set-workflow-type: invalid session-id "${sessionId}" — must match [A-Za-z0-9_-]+\n`);
  process.exit(1);
}

if (!VALID_TYPES.has(type)) {
  process.stderr.write(`set-workflow-type: invalid type "${type}" — must be one of: ${[...VALID_TYPES].join(", ")}\n`);
  process.exit(1);
}

let state = readState(sessionId);
if (!state) {
  state = createInitialState(sessionId);
}
state.workflow_type = type;
writeState(sessionId, state);
process.exit(0);
