#!/usr/bin/env bash
# Validate a single codex concern line for hook-scope claims.
# Usage: validate-hook-scope-concern "<concern-text>"
#        or: echo "<concern-text>" | validate-hook-scope-concern
#
# Exit 0 — concern accepted (no hook-scope keyword, or annotation present).
# Exit 1 — concern rejected; reason on stderr.
#           Caller must NOT add this concern to the ledger.
#
# Hook-scope keywords: enforce-issue-close, PreToolUse, ISSUE_CLOSE_SKILL,
#   command-head.js.  These identify claims about hook behavior or runtime
#   architecture that require source verification before being credible.
#
# Required annotation format (inline on the concern line):
#   [verified: <one-or-more-filenames>]
#
# The annotation declares which source files the reviewer read via read_file.
# Its presence is checked mechanically; its truthfulness is the reviewer's
# attestation (auditable in the codex session transcript).

set -euo pipefail

TEXT="${1:-}"
if [[ -z "$TEXT" ]]; then
  TEXT=$(cat)
fi

HOOK_SCOPE_RE='enforce-issue-close|PreToolUse|ISSUE_CLOSE_SKILL|command-head\.js'
# Requires at least one non-space, non-] character after "verified:" to prevent
# [verified: ] (space only) from matching via backtracking.
VERIFIED_RE='\[verified:[[:space:]]*[^][:space:]][^]]*\]'

if [[ "$TEXT" =~ $HOOK_SCOPE_RE ]] && [[ ! "$TEXT" =~ $VERIFIED_RE ]]; then
  echo "hook-scope claim without [verified: <files>] annotation (keywords matched: enforce-issue-close | PreToolUse | ISSUE_CLOSE_SKILL | command-head.js)" >&2
  exit 1
fi
exit 0
