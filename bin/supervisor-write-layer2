#!/usr/bin/env node
"use strict";

const { writeLayer2State, confirmFinding, dropFindings, incrementL2RetryCount } = require("../hooks/lib/supervisor-state-writer");
const { SEVERITY_VALUES, L2_PHASE_VALUES, L2_ELIGIBLE_PHASE_VALUES } = require("../hooks/lib/supervisor-state-schema");

const SESSION_ID_RE = /^[A-Za-z0-9_-]+$/;

const KNOWN_VALUE_FLAGS = new Set([
  "--session-id",
  "--l2-armed-at",
  "--last-run-at",
  "--cumulative-severity",
  "--finding-categories",
  "--finding-severity",
  "--finding-detail",
  "--finding-reporter",
  "--finding-status",
  "--confirm-finding-ids",
  "--drop-finding-ids",
  "--set-l2-phase",
  "--set-l2-eligible-phase",
]);
const KNOWN_BOOL_FLAGS = new Set(["--clear-l2-armed-at", "--increment-l2-retry-count", "--mark-findings-surfaced"]);

function usage(msg) {
  if (msg) console.error(`[supervisor-write-layer2] ERROR: ${msg}`);
  console.error(
    "Usage: node bin/supervisor-write-layer2 --session-id <sid>" +
    " [--l2-armed-at <iso>] [--clear-l2-armed-at]" +
    " [--last-run-at <iso>] [--cumulative-severity <error|warning|notice|null>]" +
    " [--finding-categories <csv> --finding-severity <s>" +
    " --finding-detail <text> --finding-reporter <name>" +
    " [--finding-status <draft|confirmed>]]" +
    " [--confirm-finding-ids <csv>] [--drop-finding-ids <csv>]" +
    " [--set-l2-phase <pending|done|frozen>]" +
    " [--mark-findings-surfaced] [--set-l2-eligible-phase <post_final_report_window|null>]"
  );
  process.exit(1);
}

const args = {};
const flags = new Set();
const argv = process.argv.slice(2);
for (let i = 0; i < argv.length; i++) {
  const tok = argv[i];
  if (KNOWN_BOOL_FLAGS.has(tok)) {
    flags.add(tok);
    continue;
  }
  if (KNOWN_VALUE_FLAGS.has(tok)) {
    if (i + 1 >= argv.length) usage(`${tok} requires a value`);
    args[tok.slice(2)] = argv[i + 1];
    i++;
    continue;
  }
  usage(`unknown flag: ${tok}`);
}

const sid = args["session-id"];
if (!sid || !SESSION_ID_RE.test(sid)) usage("--session-id required (valid alphanumeric/dash/underscore)");

const hasL2ArmedAt = "l2-armed-at" in args;
const hasClearL2ArmedAt = flags.has("--clear-l2-armed-at");
const hasLastRunAt = "last-run-at" in args;
const hasCumulativeSeverity = "cumulative-severity" in args;
const hasSetL2Phase = "set-l2-phase" in args;
const hasFindingStatus = "finding-status" in args;
const hasConfirmIds = "confirm-finding-ids" in args;
const hasDropIds = "drop-finding-ids" in args;
const hasMarkFindingsSurfaced = flags.has("--mark-findings-surfaced");
const hasSetL2EligiblePhase = "set-l2-eligible-phase" in args;

const findingKeys = ["finding-categories", "finding-severity", "finding-detail", "finding-reporter"];
const findingPresent = findingKeys.filter((k) => k in args);
const hasAnyFinding = findingPresent.length > 0;
const hasAllFindings = findingPresent.length === findingKeys.length;

if (hasL2ArmedAt && hasClearL2ArmedAt) {
  usage("--l2-armed-at and --clear-l2-armed-at are mutually exclusive");
}

if (hasSetL2Phase && args["set-l2-phase"] === "frozen" && hasL2ArmedAt) {
  usage("--set-l2-phase frozen and --l2-armed-at are mutually exclusive");
}

if (hasAnyFinding && !hasAllFindings) {
  usage("--finding-categories, --finding-severity, --finding-detail, --finding-reporter must all be provided together");
}

if (hasFindingStatus && !hasAllFindings) {
  usage("--finding-status requires --finding-* flags");
}

if (hasFindingStatus && !["draft", "confirmed"].includes(args["finding-status"])) {
  usage("--finding-status must be one of draft|confirmed");
}

function parseIdCsv(raw, flag) {
  const parts = raw.split(",").map((s) => s.trim()).filter(Boolean);
  const ids = [];
  for (const p of parts) {
    const n = Number(p);
    if (!Number.isInteger(n)) usage(`${flag} contains non-integer: ${p}`);
    ids.push(n);
  }
  if (ids.length === 0) usage(`${flag} must be non-empty`);
  return ids;
}

const hasIncrementRetry = flags.has("--increment-l2-retry-count");

if (hasIncrementRetry) {
  const hasOtherMutating = hasL2ArmedAt || hasClearL2ArmedAt || hasLastRunAt || hasCumulativeSeverity ||
    hasSetL2Phase || hasAnyFinding || hasConfirmIds || hasDropIds || hasMarkFindingsSurfaced || hasSetL2EligiblePhase;
  if (hasOtherMutating) {
    usage("--increment-l2-retry-count is mutually exclusive with other mutating flags");
  }
  const result = incrementL2RetryCount(sid);
  console.log(JSON.stringify(result));
  process.exit(0);
}

if (!hasL2ArmedAt && !hasClearL2ArmedAt && !hasLastRunAt && !hasCumulativeSeverity && !hasAnyFinding && !hasSetL2Phase && !hasConfirmIds && !hasDropIds && !hasMarkFindingsSurfaced && !hasSetL2EligiblePhase) {
  usage("at least one mutating flag required");
}

const patch = {};

if (hasL2ArmedAt) patch.l2_armed_at = args["l2-armed-at"];
if (hasClearL2ArmedAt) patch.l2_armed_at = null;
if (hasLastRunAt) patch.last_run_at = args["last-run-at"];

if (hasCumulativeSeverity) {
  const raw = args["cumulative-severity"];
  if (raw === "null") {
    patch.cumulative_severity = null;
  } else if (SEVERITY_VALUES.includes(raw)) {
    patch.cumulative_severity = raw;
  } else {
    usage(`--cumulative-severity must be one of ${SEVERITY_VALUES.join("|")}|null`);
  }
}

if (hasSetL2Phase) {
  const raw = args["set-l2-phase"];
  if (!["pending", "done", "frozen"].includes(raw)) usage("--set-l2-phase must be one of pending|done|frozen");
  patch.l2_phase = raw;
  if (patch.l2_phase === "done") patch.l2_retry_count = 0;
}

if (hasMarkFindingsSurfaced) patch.findings_surfaced_at = new Date().toISOString();

if (hasSetL2EligiblePhase) {
  const raw = args["set-l2-eligible-phase"];
  if (raw === "null") {
    patch.l2_eligible_phase = null;
  } else if (L2_ELIGIBLE_PHASE_VALUES.includes(raw)) {
    patch.l2_eligible_phase = raw;
  } else {
    usage(`--set-l2-eligible-phase must be one of ${L2_ELIGIBLE_PHASE_VALUES.filter(v => v !== null).join("|")}|null`);
  }
}

if (hasAllFindings) {
  const categories = args["finding-categories"].split(",").map((s) => s.trim()).filter(Boolean);
  if (categories.length === 0) usage("--finding-categories must be non-empty");
  const finding = {
    categories,
    severity: args["finding-severity"],
    detail: args["finding-detail"],
    reporter: args["finding-reporter"],
  };
  if (hasFindingStatus && args["finding-status"] === "draft") {
    finding.status = "draft";
  } else if (hasFindingStatus && args["finding-status"] === "confirmed") {
    finding.status = "confirmed";
  }
  patch.findings = [finding];
}

// Order of operations:
//   1. writeLayer2State without l2_phase (append + scalars except phase)
//   2. confirmFinding for each --confirm-finding-ids
//   3. dropFindings for --drop-finding-ids
//   4. writeLayer2State with only l2_phase (committed last)
const phasePatch = ("l2_phase" in patch) ? { l2_phase: patch.l2_phase } : null;
if (phasePatch) delete patch.l2_phase;

const hasAnyPrePhase =
  Object.keys(patch).length > 0;

if (hasAnyPrePhase) {
  const ok = writeLayer2State(sid, patch);
  if (!ok) {
    console.error("[supervisor-write-layer2] ERROR: writeLayer2State failed (invalid fields or unexpected error)");
    process.exit(1);
  }
}

if (hasConfirmIds) {
  const ids = parseIdCsv(args["confirm-finding-ids"], "--confirm-finding-ids");
  for (const idx of ids) {
    if (!confirmFinding(sid, idx)) {
      console.error("[supervisor-write-layer2] ERROR: confirmFinding failed");
      process.exit(1);
    }
  }
}

if (hasDropIds) {
  const ids = parseIdCsv(args["drop-finding-ids"], "--drop-finding-ids");
  if (!dropFindings(sid, ids)) {
    console.error("[supervisor-write-layer2] ERROR: dropFindings failed");
    process.exit(1);
  }
}

if (phasePatch) {
  const ok = writeLayer2State(sid, phasePatch);
  if (!ok) {
    console.error("[supervisor-write-layer2] ERROR: writeLayer2State (phase) failed");
    process.exit(1);
  }
}
process.exit(0);
