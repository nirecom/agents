#!/usr/bin/env node
"use strict";

const { writeLayer3State, incrementL3RetryCount } = require("../hooks/lib/supervisor-state-writer");
const { L3_PHASE_VALUES, L3_VERDICT_VALUES } = require("../hooks/lib/supervisor-state-schema");
const { resolveSessionId } = require("../hooks/lib/workflow-state");
const { resolveWorkflowSessionId } = require("../hooks/lib/resolve-workflow-session-id");

const SESSION_ID_RE = /^[A-Za-z0-9_-]+$/;

const KNOWN_VALUE_FLAGS = new Set([
  "--session-id",
  "--mirror-session-id",
  "--l3-armed-at",
  "--last-run-at",
  "--set-l3-phase",
  "--set-l3-verdict",
  "--l3-cause",
]);
const KNOWN_BOOL_FLAGS = new Set(["--clear-l3-armed-at", "--increment-l3-retry-count"]);

function usage(msg) {
  if (msg) console.error(`[supervisor-write-layer3] ERROR: ${msg}`);
  console.error(
    "Usage: node bin/supervisor-write-layer3 [--session-id <sid>] [--mirror-session-id <sid>]" +
    " [--l3-armed-at <iso>] [--clear-l3-armed-at]" +
    " [--last-run-at <iso>]" +
    " [--set-l3-phase <pending|in_progress|done|frozen>]" +
    " [--set-l3-verdict <CONTINUE|WARN|BLOCK>]" +
    " [--l3-cause <text>]" +
    " [--increment-l3-retry-count]"
  );
  process.exit(1);
}

const args = {};
const flags = new Set();
const argv = process.argv.slice(2);
for (let i = 0; i < argv.length; i++) {
  const tok = argv[i];
  if (KNOWN_BOOL_FLAGS.has(tok)) { flags.add(tok); continue; }
  if (KNOWN_VALUE_FLAGS.has(tok)) {
    if (i + 1 >= argv.length) usage(`${tok} requires a value`);
    args[tok.slice(2)] = argv[i + 1];
    i++;
    continue;
  }
  usage(`unknown flag: ${tok}`);
}

// Session-ID resolution: CLI flag → WORKFLOW_SESSION_ID env (wsid) →
// CLAUDE_SESSION_ID env (CC UUID) → error.
// Track source so the dual-store mirror-write below can resolve the "other"
// identity automatically when --mirror-session-id is not explicit.
// NOTE: We intentionally do NOT fall back to WORKTREE_NOTES.md / plans-dir
// scan auto-resolve here — callers without an env or flag must error out so
// the writer cannot land in an unintended store.
let rawSid = args["session-id"];
let rawSidSource = "explicit";
if (!rawSid) {
  const envWsid = process.env.WORKFLOW_SESSION_ID;
  if (envWsid && SESSION_ID_RE.test(envWsid)) { rawSid = envWsid; rawSidSource = "wsid"; }
}
if (!rawSid) {
  const envCc = process.env.CLAUDE_SESSION_ID;
  if (envCc && SESSION_ID_RE.test(envCc)) { rawSid = envCc; rawSidSource = "ccuuid"; }
}
if (!rawSid || !SESSION_ID_RE.test(rawSid)) {
  console.error("Error: --session-id required (could not auto-resolve)");
  process.exit(1);
}

const hasL3ArmedAt = "l3-armed-at" in args;
const hasClearL3ArmedAt = flags.has("--clear-l3-armed-at");
const hasLastRunAt = "last-run-at" in args;
const hasSetL3Phase = "set-l3-phase" in args;
const hasSetL3Verdict = "set-l3-verdict" in args;
const hasL3Cause = "l3-cause" in args;
const hasIncrementRetry = flags.has("--increment-l3-retry-count");

if (hasL3ArmedAt && hasClearL3ArmedAt) usage("--l3-armed-at and --clear-l3-armed-at are mutually exclusive");

if (hasIncrementRetry) {
  const hasOther = hasL3ArmedAt || hasClearL3ArmedAt || hasLastRunAt || hasSetL3Phase || hasSetL3Verdict || hasL3Cause;
  if (hasOther) usage("--increment-l3-retry-count is mutually exclusive with other mutating flags");
  const result = incrementL3RetryCount(rawSid);
  console.log(JSON.stringify(result));
  process.exit(0);
}

if (!hasL3ArmedAt && !hasClearL3ArmedAt && !hasLastRunAt && !hasSetL3Phase && !hasSetL3Verdict && !hasL3Cause) {
  usage("at least one mutating flag required");
}

const patch = {};
if (hasL3ArmedAt) patch.l3_armed_at = args["l3-armed-at"];
if (hasClearL3ArmedAt) patch.l3_armed_at = null;
if (hasLastRunAt) patch.l3_last_run_at = args["last-run-at"];
if (hasL3Cause) patch.l3_cause = args["l3-cause"];

if (hasSetL3Phase) {
  const raw = args["set-l3-phase"];
  // Exclude null from the user-facing enum (null is internal-only via writer).
  const allowed = L3_PHASE_VALUES.filter((v) => v !== null);
  if (!allowed.includes(raw)) usage(`--set-l3-phase must be one of ${allowed.join("|")}`);
  patch.l3_phase = raw;
  if (raw === "done") {
    patch.l3_retry_count = 0;
    // Auto-populate l3_last_run_at so dedup in Phase A works without requiring --last-run-at.
    if (!hasLastRunAt) patch.l3_last_run_at = new Date().toISOString();
  }
}

if (hasSetL3Verdict) {
  const raw = args["set-l3-verdict"];
  if (!L3_VERDICT_VALUES.includes(raw)) usage(`--set-l3-verdict must be one of ${L3_VERDICT_VALUES.join("|")}`);
  patch.l3_verdict = raw;
}

const ok = writeLayer3State(rawSid, patch);
if (!ok) {
  console.error("[supervisor-write-layer3] ERROR: writeLayer3State failed (invalid fields or unexpected error)");
  process.exit(1);
}

// #1052: Identity-agnostic dual-store mirror-write. Mirror only when rawSidSource
// is auto-resolved OR explicit --mirror-session-id was supplied; explicit
// --session-id without --mirror-session-id writes only to the named store.
let mirrorSid = args["mirror-session-id"];
if (!mirrorSid && rawSidSource !== "explicit") {
  if (rawSidSource === "wsid") {
    const envCc = process.env.CLAUDE_SESSION_ID;
    if (envCc && envCc !== rawSid && SESSION_ID_RE.test(envCc)) mirrorSid = envCc;
    if (!mirrorSid) {
      try {
        const ccId = resolveSessionId({ sessionIdFromInput: null, transcriptPath: null });
        if (ccId && ccId !== rawSid && SESSION_ID_RE.test(ccId)) mirrorSid = ccId;
      } catch (_) {}
    }
  } else if (rawSidSource === "ccuuid") {
    const envWs = process.env.WORKFLOW_SESSION_ID;
    if (envWs && envWs !== rawSid && SESSION_ID_RE.test(envWs)) mirrorSid = envWs;
    if (!mirrorSid) {
      try {
        const ws = resolveWorkflowSessionId({});
        if (ws && ws !== rawSid && SESSION_ID_RE.test(ws)) mirrorSid = ws;
      } catch (_) {}
    }
  }
}
if (mirrorSid && mirrorSid !== rawSid && SESSION_ID_RE.test(mirrorSid)) {
  const mirrorOk = writeLayer3State(mirrorSid, patch);
  if (!mirrorOk) {
    console.error(`[supervisor-write-layer3] WARN: mirror-write to ${mirrorSid} failed`);
  }
}

process.exit(0);
