#!/usr/bin/env node
"use strict";

const { writeLayer3State, incrementL3RetryCount } = require("../hooks/lib/supervisor-state-writer");
const { L3_PHASE_VALUES, L3_VERDICT_VALUES } = require("../hooks/lib/supervisor-state-schema");
const { resolveSessionId } = require("../hooks/lib/workflow-state");
const { resolveWorkflowSessionId } = require("../hooks/lib/resolve-workflow-session-id");

const SESSION_ID_RE = /^[A-Za-z0-9_-]+$/;

const KNOWN_VALUE_FLAGS = new Set([
  "--session-id",
  "--mirror-session-id",
  "--l3-armed-at",
  "--last-run-at",
  "--set-l3-phase",
  "--set-l3-verdict",
  "--l3-cause",
]);
const KNOWN_BOOL_FLAGS = new Set(["--clear-l3-armed-at", "--increment-l3-retry-count"]);

function usage(msg) {
  if (msg) console.error(`[supervisor-write-layer3] ERROR: ${msg}`);
  console.error(
    "Usage: node bin/supervisor-write-layer3 [--session-id <sid>] [--mirror-session-id <sid>]" +
    " [--l3-armed-at <iso>] [--clear-l3-armed-at]" +
    " [--last-run-at <iso>]" +
    " [--set-l3-phase <pending|in_progress|done|frozen>]" +
    " [--set-l3-verdict <CONTINUE|WARN|BLOCK>]" +
    " [--l3-cause <text>]" +
    " [--increment-l3-retry-count]"
  );
  process.exit(1);
}

const args = {};
const flags = new Set();
const argv = process.argv.slice(2);
for (let i = 0; i < argv.length; i++) {
  const tok = argv[i];
  if (KNOWN_BOOL_FLAGS.has(tok)) { flags.add(tok); continue; }
  if (KNOWN_VALUE_FLAGS.has(tok)) {
    if (i + 1 >= argv.length) usage(`${tok} requires a value`);
    args[tok.slice(2)] = argv[i + 1];
    i++;
    continue;
  }
  usage(`unknown flag: ${tok}`);
}

// Session-ID resolution: ordered fallback chain.
// Track source so MIRROR_RESOLVERS can find the "other" identity automatically.
// NOTE: no WORKTREE_NOTES.md / plans-dir scan — callers without env or flag must error out.
const SID_SOURCES = [
  { source: "explicit", get: () => args["session-id"] },
  { source: "wsid",     get: () => process.env.WORKFLOW_SESSION_ID },
  { source: "ccuuid",   get: () => process.env.CLAUDE_SESSION_ID },
];
let rawSid, rawSidSource;
for (const src of SID_SOURCES) {
  const val = src.get();
  if (val && SESSION_ID_RE.test(val)) { rawSid = val; rawSidSource = src.source; break; }
}
if (!rawSid) {
  console.error("Error: --session-id required (could not auto-resolve)");
  process.exit(1);
}

const FLAG_SPECS = {
  "l3-armed-at":       { kind: "value", patch: (v) => ({ l3_armed_at: v }),        mutexGroup: "armed-at" },
  "clear-l3-armed-at": { kind: "bool",  patch: ()  => ({ l3_armed_at: null }),      mutexGroup: "armed-at" },
  "last-run-at":       { kind: "value", patch: (v) => ({ l3_last_run_at: v }) },
  "l3-cause":          { kind: "value", patch: (v) => ({ l3_cause: v }) },
  "set-l3-phase": {
    kind: "value",
    validate(v) {
      const allowed = L3_PHASE_VALUES.filter((x) => x !== null);
      if (!allowed.includes(v)) usage(`--set-l3-phase must be one of ${allowed.join("|")}`);
    },
    patch(v, ctx) {
      const p = { l3_phase: v };
      if (v === "done") {
        p.l3_retry_count = 0;
        if (!ctx.activeFlags.has("last-run-at")) p.l3_last_run_at = new Date().toISOString();
      }
      return p;
    },
  },
  "set-l3-verdict": {
    kind: "value",
    validate(v) {
      if (!L3_VERDICT_VALUES.includes(v)) usage(`--set-l3-verdict must be one of ${L3_VERDICT_VALUES.join("|")}`);
    },
    patch: (v) => ({ l3_verdict: v }),
  },
};

// #1052: Identity-agnostic dual-store mirror-write.
// Mirror only when rawSidSource is auto-resolved OR explicit --mirror-session-id supplied;
// explicit --session-id without --mirror-session-id writes only to the named store.
const MIRROR_RESOLVERS = {
  explicit: () => null,
  wsid: () => {
    const envCc = process.env.CLAUDE_SESSION_ID;
    if (envCc && envCc !== rawSid && SESSION_ID_RE.test(envCc)) return envCc;
    try {
      const ccId = resolveSessionId({ sessionIdFromInput: null, transcriptPath: null });
      if (ccId && ccId !== rawSid && SESSION_ID_RE.test(ccId)) return ccId;
    } catch (_) {}
    return null;
  },
  ccuuid: () => {
    const envWs = process.env.WORKFLOW_SESSION_ID;
    if (envWs && envWs !== rawSid && SESSION_ID_RE.test(envWs)) return envWs;
    try {
      const ws = resolveWorkflowSessionId({});
      if (ws && ws !== rawSid && SESSION_ID_RE.test(ws)) return ws;
    } catch (_) {}
    return null;
  },
};

// Detect active flags
const activeFlags = new Set();
for (const flag of Object.keys(FLAG_SPECS)) {
  const spec = FLAG_SPECS[flag];
  if (spec.kind === "bool" ? flags.has(`--${flag}`) : (flag in args)) activeFlags.add(flag);
}

// Mutex group check
const groupCounts = {};
for (const flag of activeFlags) {
  const grp = FLAG_SPECS[flag].mutexGroup;
  if (grp) groupCounts[grp] = (groupCounts[grp] || 0) + 1;
}
for (const [grp, count] of Object.entries(groupCounts)) {
  if (count > 1) usage(`flags in group "${grp}" are mutually exclusive`);
}

// --increment-l3-retry-count: orthogonal terminal path (no FLAG_SPEC — handled separately)
if (flags.has("--increment-l3-retry-count")) {
  if (activeFlags.size > 0) usage("--increment-l3-retry-count is mutually exclusive with other mutating flags");
  const result = incrementL3RetryCount(rawSid);
  console.log(JSON.stringify(result));
  process.exit(0);
}

if (activeFlags.size === 0) usage("at least one mutating flag required");

// Build patch via FLAG_SPECS table
const ctx = { activeFlags };
const patch = {};
for (const flag of activeFlags) {
  const spec = FLAG_SPECS[flag];
  const value = spec.kind === "bool" ? true : args[flag];
  if (spec.validate) spec.validate(value);
  Object.assign(patch, spec.patch(value, ctx));
}

const ok = writeLayer3State(rawSid, patch);
if (!ok) {
  console.error("[supervisor-write-layer3] ERROR: writeLayer3State failed (invalid fields or unexpected error)");
  process.exit(1);
}

// Mirror-write via MIRROR_RESOLVERS table
let mirrorSid = args["mirror-session-id"];
if (!mirrorSid) mirrorSid = MIRROR_RESOLVERS[rawSidSource]();
if (mirrorSid && mirrorSid !== rawSid && SESSION_ID_RE.test(mirrorSid)) {
  const mirrorOk = writeLayer3State(mirrorSid, patch);
  if (!mirrorOk) console.error(`[supervisor-write-layer3] WARN: mirror-write to ${mirrorSid} failed`);
}

process.exit(0);
