#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");
const { execSync } = require("child_process");
const { appendFinding } = require("../hooks/lib/supervisor-state-writer");
const { resolveSessionId } = require("../hooks/lib/workflow-state");

const SESSION_ID_RE = /^[A-Za-z0-9_-]+$/;

function usage(msg) {
  if (msg) console.error(`[supervisor-report] ERROR: ${msg}`);
  console.error(
    "Usage: node bin/supervisor-report" +
    " --categories <cat1,cat2>" +
    " --severity <error|warning|notice>" +
    " --detail <text>" +
    " --reporter <name>" +
    " [--session-id <sid>]"
  );
  process.exit(1);
}

function readSessionIdFromNotes(notesPath) {
  try {
    const content = fs.readFileSync(notesPath, "utf8");
    const m = content.match(/^Session-ID:\s*(\S+)\s*$/m);
    if (m) return m[1];
  } catch (_) {
    // ignore
  }
  return null;
}

function autoResolveSessionId() {
  // Level 1: CLAUDE_SESSION_ID env var (best-effort; unreliable in subprocesses — Anthropic bug #27987)
  if (process.env.CLAUDE_SESSION_ID && SESSION_ID_RE.test(process.env.CLAUDE_SESSION_ID)) {
    return process.env.CLAUDE_SESSION_ID;
  }
  // Level 2: CWD WORKTREE_NOTES.md
  const cwdNotes = path.join(process.cwd(), "WORKTREE_NOTES.md");
  const fromCwd = readSessionIdFromNotes(cwdNotes);
  if (fromCwd && SESSION_ID_RE.test(fromCwd)) return fromCwd;
  // Level 3: git common-dir's parent WORKTREE_NOTES.md
  try {
    const commonDir = execSync("git rev-parse --git-common-dir", {
      encoding: "utf8",
      timeout: 2000,
      stdio: ["pipe", "pipe", "pipe"],
    }).trim();
    if (commonDir) {
      const notesPath = path.join(path.resolve(commonDir), "..", "WORKTREE_NOTES.md");
      const fromGit = readSessionIdFromNotes(notesPath);
      if (fromGit && SESSION_ID_RE.test(fromGit)) return fromGit;
    }
  } catch (_) {
    // ignore
  }
  // Level 4: resolveSessionId() from workflow-state
  try {
    const sid = resolveSessionId();
    if (sid && SESSION_ID_RE.test(sid)) return sid;
  } catch (_) {
    // ignore
  }
  return null;
}

const args = {};
const argv = process.argv.slice(2);
for (let i = 0; i < argv.length; i++) {
  if (argv[i].startsWith("--") && i + 1 < argv.length) {
    args[argv[i].slice(2)] = argv[i + 1];
    i++;
  }
}

const categoriesRaw = args["categories"];
const severity = args["severity"];
const detail = args["detail"];
const reporter = args["reporter"];

if (!categoriesRaw) usage("--categories required");
if (!severity) usage("--severity required");
if (detail === undefined) usage("--detail required");
if (!reporter) usage("--reporter required");

// Session-ID resolution: CLI flag → auto-resolve chain → usage error
let rawSid = args["session-id"];
if (!rawSid) {
  rawSid = autoResolveSessionId();
}
if (!rawSid || !SESSION_ID_RE.test(rawSid)) {
  console.error("Error: --session-id required (could not auto-resolve)");
  process.exit(1);
}

const categories = categoriesRaw.split(",").map((s) => s.trim()).filter(Boolean);
if (categories.length === 0) usage("--categories must be non-empty");

const ok = appendFinding(rawSid, { categories, severity, detail, reporter });
if (!ok) {
  console.error("[supervisor-report] ERROR: appendFinding failed (invalid fields or unexpected error)");
  process.exit(1);
}
process.exit(0);
