#!/usr/bin/env bash
# bin/compose-history-entry
# Append a docs/history.md entry from WORKTREE_NOTES.md ## History Notes and commit it.
# Usage: see detail plan. Run from the linked worktree (ENFORCE_WORKTREE=on) or main worktree (off).
set -euo pipefail

WORKTREE_NOTES=""
SUBJECT=""
DATE="$(date +%Y-%m-%d)"
CATEGORY="FEATURE"
COMMITS=""
BACKGROUND_OVERRIDE=""
NO_TRANSLATE=0
DRY_RUN=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --worktree-notes) WORKTREE_NOTES="$2"; shift 2 ;;
        --subject)        SUBJECT="$2";        shift 2 ;;
        --date)           DATE="$2";           shift 2 ;;
        --category)       CATEGORY="$2";       shift 2 ;;
        --commits)        COMMITS="$2";        shift 2 ;;
        --background)     BACKGROUND_OVERRIDE="$2"; shift 2 ;;
        --no-translate)   NO_TRANSLATE=1;      shift ;;
        --dry-run)        DRY_RUN=1;           shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

worktree_root="$(git rev-parse --show-toplevel)"

# Resolve WORKTREE_NOTES.md path
if [[ -z "$WORKTREE_NOTES" ]]; then
    WORKTREE_NOTES="$worktree_root/WORKTREE_NOTES.md"
fi

NOTES_MISSING=0
if [[ ! -f "$WORKTREE_NOTES" ]]; then
    echo "compose-history-entry: WORKTREE_NOTES.md not found at $WORKTREE_NOTES; synthesizing Changes from git log" >&2
    NOTES_MISSING=1
fi

# Extract ## History Notes bullets (CRLF-safe)
CHANGES=""
if [[ "$NOTES_MISSING" -eq 0 ]]; then
    NOTES_BLOCK="$(tr -d '\r' < "$WORKTREE_NOTES" | awk '
        /^## History Notes[[:space:]]*$/ { in_section=1; next }
        in_section && /^## / { in_section=0 }
        in_section && /^- / && !/^- \(none\)/ { sub(/^- /, ""); print }
    ')"
    if [[ -z "$NOTES_BLOCK" ]]; then
        echo "compose-history-entry: History Notes is (none); skipping" >&2
        exit 0
    fi
    # Join bullets with "; " (no newlines — doc-append expects single-line)
    CHANGES="$(printf '%s' "$NOTES_BLOCK" | tr '\n' ';' | sed 's/;$//' | sed 's/;/; /g')"
fi

# Resolve --commits default
if [[ -z "$COMMITS" ]]; then
    MERGE_BASE_REF="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|^refs/remotes/||' || true)"
    if [[ -n "$MERGE_BASE_REF" ]]; then
        merge_base="$(git merge-base HEAD "$MERGE_BASE_REF" 2>/dev/null || true)"
    fi
    if [[ -z "${merge_base:-}" ]]; then
        merge_base="$(git merge-base HEAD origin/main 2>/dev/null || true)"
    fi
    if [[ -z "${merge_base:-}" ]]; then
        merge_base="$(git log -1 --format=%H HEAD^ 2>/dev/null || true)"
    fi
    if [[ -n "${merge_base:-}" ]]; then
        COMMITS="$(git log --format=%h --reverse "${merge_base}..HEAD" 2>/dev/null | head -5 | tr '\n' ',' | sed 's/,$//')"
    fi
    if [[ -z "$COMMITS" ]]; then
        COMMITS="$(git log -1 --format=%h 2>/dev/null || true)"
    fi
fi

# Idempotency check — use first commit hash in the list
first_commit_hash="$(printf '%s' "$COMMITS" | tr ',' '\n' | head -1 | tr -d ' ')"
if [[ -n "$first_commit_hash" ]]; then
    if grep -rqE "^### .*(${first_commit_hash})" \
            "${worktree_root}/docs/history.md" "${worktree_root}/docs/history/" 2>/dev/null; then
        echo "compose-history-entry: entry exists for ${first_commit_hash}; skipping" >&2
        exit 0
    fi
fi

# Resolve subject
if [[ -z "$SUBJECT" ]]; then
    SUBJECT="$(git log -1 --format=%s)"
fi

# Resolve background
if [[ -n "$BACKGROUND_OVERRIDE" ]]; then
    BACKGROUND="$BACKGROUND_OVERRIDE"
else
    BACKGROUND="Workflow session: ${SUBJECT}"
fi

# Synthesize Changes from git log if notes were missing
if [[ "$NOTES_MISSING" -eq 1 ]]; then
    if [[ -n "${merge_base:-}" ]]; then
        CHANGES="$(git log "${merge_base}..HEAD" --format=%s 2>/dev/null | tr '\n' ';' | sed 's/;$//' | sed 's/;/; /g')"
    fi
    if [[ -z "$CHANGES" ]]; then
        CHANGES="$(git log -1 --format=%s)"
    fi
fi

# Translation (pass-through + non-ASCII warning)
if [[ "$NO_TRANSLATE" -eq 0 ]]; then
    # Resolve helper relative to this CLI (repo-agnostic — works from any caller repo)
    cli_dir="$(cd "$(dirname "$0")" && pwd)"
    # shellcheck source=bin/lib/translate-to-english.sh
    source "$cli_dir/lib/translate-to-english.sh"
    SUBJECT="$(translate_to_english "$SUBJECT")"
    BACKGROUND="$(translate_to_english "$BACKGROUND")"
    CHANGES="$(translate_to_english "$CHANGES")"
fi

# Build doc-append argv
DOC_APPEND_ARGS=(
    docs/history.md
    --category "$CATEGORY"
    --date "$DATE"
    --subject "$SUBJECT"
    --background "$BACKGROUND"
    --changes "$CHANGES"
)
if [[ -n "$COMMITS" ]]; then
    DOC_APPEND_ARGS+=(--commits "$COMMITS")
fi

if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'doc-append'
    for arg in "${DOC_APPEND_ARGS[@]}"; do
        # Wrap in single quotes (escape any embedded single quotes) so spaces
        # and special chars are preserved literally for grep-based assertions.
        escaped="${arg//\'/\'\\\'\'}"
        printf " '%s'" "$escaped"
    done
    printf '\n'
    exit 0
fi

# Append entry (write to caller's repo — repo-agnostic)
cd "$worktree_root"
doc-append "${DOC_APPEND_ARGS[@]}"

# Commit exactly the docs/history paths without disturbing other staged changes.
# --only commits from working tree and leaves other staged changes in the index.
# (linked worktree — enforce-worktree.js unconditionally allows; no ISSUE_CLOSE_SKILL=1)
git commit --only docs/history.md docs/history/ -m "docs(history): $SUBJECT"
