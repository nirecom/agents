#!/usr/bin/env node
'use strict';
const path = require('path');
try {
  const { parseIssueToken } = require(
    path.join(path.dirname(__dirname), 'hooks', 'lib', 'parse-closes-issues.js')
  );
  const raw = process.argv.slice(2).join(' ');
  const tokens = raw.split(/[\s,\n]+/).filter(Boolean);
  const results = tokens.map(parseIssueToken).filter(Boolean);
  console.log(JSON.stringify(results));
} catch (e) {
  process.stderr.write('[parse-issue-tokens] ' + e.message + '\n');
  console.log('[]');
  process.exit(0); // never-abort
}
