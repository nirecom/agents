#!/bin/bash
# bin/compose-doc-append-entry
# Reads WORKTREE_NOTES.md ## History Notes / ## Changelog Notes sections and
# updates docs/history.md and CHANGELOG.md on the default branch via the
# GitHub REST API. Atomic when both files change (Git Data API); otherwise
# uses the Contents API for single-file writes.
#
# Replaces the prior COMPOSE_DOC_APPEND_SKILL=1 env-var bypass (removed in #672).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Argument parsing ---
NOTES_PATH=""
BRANCH=""
PR_NUMBER=""
MERGE_COMMIT=""
BACKGROUND=""
CATEGORY="FEATURE"
DRY_RUN=0
CLOSES_ISSUES_COUNT=0
TARGET_HISTORY=""
TARGET_CHANGELOG=""
BOOTSTRAP=0
REPO_OVERRIDE=""
HISTORY_ONLY=0
CHANGELOG_ONLY=0
TEST_GAP=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --notes)       NOTES_PATH="$2";    shift 2 ;;
        --branch)      BRANCH="$2";        shift 2 ;;
        --pr)          PR_NUMBER="$2";     shift 2 ;;
        --merge-commit) MERGE_COMMIT="$2"; shift 2 ;;
        --background)  BACKGROUND="$2";   shift 2 ;;
        --category)    CATEGORY="$2";     shift 2 ;;
        --test-gap)    TEST_GAP="$2";      shift 2 ;;
        --dry-run)     DRY_RUN=1;         shift ;;
        --bootstrap)   BOOTSTRAP=1;       shift ;;
        --closes-issues-count) CLOSES_ISSUES_COUNT="$2"; shift 2 ;;
        --target-history)   TARGET_HISTORY="$2";   shift 2 ;;
        --target-changelog) TARGET_CHANGELOG="$2"; shift 2 ;;
        --repo)        REPO_OVERRIDE="$2"; shift 2 ;;
        --history)     HISTORY_ONLY=1;     shift ;;
        --changelog)   CHANGELOG_ONLY=1;   shift ;;
        *) echo "compose-doc-append-entry: unknown argument: $1" >&2; exit 1 ;;
    esac
done

# Validate --closes-issues-count is digits-only
[[ "$CLOSES_ISSUES_COUNT" =~ ^[0-9]+$ ]] || { echo "compose-doc-append-entry: --closes-issues-count must be digits only (got: $CLOSES_ISSUES_COUNT)" >&2; exit 1; }

# --- Validation ---
[[ -n "$NOTES_PATH" ]] || { echo "compose-doc-append-entry: --notes is required" >&2; exit 1; }
[[ -n "$BRANCH" ]] || { echo "compose-doc-append-entry: --branch is required" >&2; exit 1; }

# --bootstrap and --pr are mutually exclusive; exactly one must be supplied (issue #772).
if [[ "$BOOTSTRAP" -eq 1 && -n "$PR_NUMBER" ]]; then
    echo "compose-doc-append-entry: --bootstrap and --pr are mutually exclusive" >&2
    exit 1
fi
if [[ "$BOOTSTRAP" -eq 0 && -z "$PR_NUMBER" ]]; then
    echo "compose-doc-append-entry: --pr is required (or pass --bootstrap)" >&2
    exit 1
fi
if [[ "$BOOTSTRAP" -eq 1 ]]; then
    # In bootstrap mode the merge commit IS the bootstrap commit; require it.
    [[ -n "$MERGE_COMMIT" ]] || { echo "compose-doc-append-entry: --bootstrap requires --merge-commit" >&2; exit 1; }
fi

# Validate --pr is digits-only (only when supplied)
if [[ -n "$PR_NUMBER" ]]; then
    [[ "$PR_NUMBER" =~ ^[0-9]+$ ]] || { echo "compose-doc-append-entry: --pr must be digits only (got: $PR_NUMBER)" >&2; exit 1; }
fi

# Validate --branch has no shell metacharacters
[[ "$BRANCH" =~ ^[A-Za-z0-9._/+-]+$ ]] || { echo "compose-doc-append-entry: --branch contains invalid characters (got: $BRANCH)" >&2; exit 1; }

# Validate --merge-commit if provided (7-40 hex chars or empty)
if [[ -n "$MERGE_COMMIT" ]]; then
    [[ "$MERGE_COMMIT" =~ ^[0-9a-f]{7,40}$ ]] || {
        echo "compose-doc-append-entry: --merge-commit must be 7-40 hex chars (got: $MERGE_COMMIT)" >&2
        exit 1
    }
fi

# Validate --repo if provided (OWNER/REPO — alphanumeric, dots, dashes, underscores only)
if [[ -n "${REPO_OVERRIDE:-}" ]]; then
    [[ "$REPO_OVERRIDE" =~ ^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$ ]] || {
        echo "compose-doc-append-entry: --repo must be OWNER/REPO (got: $REPO_OVERRIDE)" >&2
        exit 1
    }
fi

# --history and --changelog are mutually exclusive
if [[ "${HISTORY_ONLY:-0}" -eq 1 && "${CHANGELOG_ONLY:-0}" -eq 1 ]]; then
    echo "compose-doc-append-entry: --history and --changelog are mutually exclusive" >&2
    exit 1
fi

# --- Bail: notes file missing ---
if [[ ! -f "$NOTES_PATH" ]]; then
    exit 0
fi

# --- Staging directory ---
if [[ -z "${AGENTS_CONFIG_DIR:-}" ]]; then
    echo "compose-doc-append-entry: AGENTS_CONFIG_DIR is required" >&2
    exit 1
fi
STAGING_DIR=$(bash "$AGENTS_CONFIG_DIR/bin/workflow-plans-dir")
mkdir -p "$STAGING_DIR" "$STAGING_DIR/markers"

# --- Extract section helper ---
extract_section() {
    local heading="$1"
    node -e "
const fs = require('fs');
const text = fs.readFileSync(process.argv[1], 'utf8');
const lines = text.split('\n');
let inSection = false;
const bullets = [];
for (const line of lines) {
    if (line === '## ' + process.argv[2]) { inSection = true; continue; }
    if (inSection && line.startsWith('## ')) break;
    if (inSection && line.startsWith('- ')) {
        const content = line.slice(2).trim();
        if (content && content !== '(none)') bullets.push(content);
    }
}
process.stdout.write(bullets.join('\n'));
" -- "$NOTES_PATH" "$heading"
}

# --- Background derivation ---
derive_background() {
    if [[ -n "$BACKGROUND" ]]; then
        echo "$BACKGROUND"
        return
    fi
    if [[ "$BOOTSTRAP" -eq 1 ]]; then
        echo "Bootstrap initial commit pushed on $(date +%F)."
        return
    fi
    local gh_title
    gh_title="$(gh pr view "$PR_NUMBER" --json title --jq .title 2>/dev/null || true)"
    if [[ -n "$gh_title" ]]; then
        echo "$gh_title"
        return
    fi
    echo "PR #${PR_NUMBER} merged on $(date +%F)."
}

# --- Idempotency: per-branch marker files in staging dir ---
# Normal mode keys by PR number; bootstrap mode (#772) has no PR, so it keys
# by the bootstrap commit SHA instead. Repo+branch+merge-commit is unique
# enough to prevent duplicate writes on retry.
ENCODED_BRANCH="${BRANCH//\//%2F}"
if [[ "$BOOTSTRAP" -eq 1 ]]; then
    MARKER_HISTORY="$STAGING_DIR/markers/${ENCODED_BRANCH}-bootstrap-${MERGE_COMMIT}-history"
    MARKER_CHANGELOG="$STAGING_DIR/markers/${ENCODED_BRANCH}-bootstrap-${MERGE_COMMIT}-changelog"
else
    MARKER_HISTORY="$STAGING_DIR/markers/${ENCODED_BRANCH}-pr${PR_NUMBER}-history"
    MARKER_CHANGELOG="$STAGING_DIR/markers/${ENCODED_BRANCH}-pr${PR_NUMBER}-changelog"
fi

history_sentinel_found() {
    [[ -f "$MARKER_HISTORY" ]]
}
write_history_marker() {
    printf '%s\n%s\n' "${MERGE_COMMIT:-}" "$(date -u +%FT%TZ)" > "$MARKER_HISTORY"
}

changelog_marker_found() {
    [[ -f "$MARKER_CHANGELOG" ]]
}
write_changelog_marker() {
    printf '%s\n%s\n' "${MERGE_COMMIT:-}" "$(date -u +%FT%TZ)" > "$MARKER_CHANGELOG"
}

# --- Language lint (WORKTREE_NOTES.md sections) ---
LANG_VIOLATIONS="$(
    NOTES_PATH="$NOTES_PATH" \
    AGENTS_CONFIG_DIR="$AGENTS_CONFIG_DIR" \
    env -u DOCS_LANG_HISTORY_PUBLIC -u DOCS_LANG_HISTORY_PRIVATE -u DOCS_LANG_CHANGELOG_PUBLIC -u DOCS_LANG_CHANGELOG_PRIVATE node -e '
        const fs = require("fs");
        const path = require("path");
        const agentsDir = process.env.AGENTS_CONFIG_DIR;
        const notesPath = process.env.NOTES_PATH;
        let cfgMod, lintMod, privMod;
        try {
            cfgMod = require(path.join(agentsDir, "hooks/lib/lang-config.js"));
            lintMod = require(path.join(agentsDir, "hooks/lib/lint-worktree-notes-lang.js"));
            privMod = require(path.join(agentsDir, "hooks/lib/is-private-repo.js"));
        } catch (e) { process.exit(0); }
        let content;
        try { content = fs.readFileSync(notesPath, "utf8"); } catch (e) { process.exit(0); }
        const config = cfgMod.loadDocsLangConfig();
        let priv = false;
        try { priv = privMod.isPrivateRepo(process.cwd()) === true; } catch (e) {}
        const violations = lintMod.lintWorktreeNotesLang(content, config, {
            isPrivateRepo: priv,
        });
        if (violations.length > 0) {
            process.stdout.write(JSON.stringify(violations));
        }
    ' 2>/dev/null || true
)"
if [[ -n "$LANG_VIOLATIONS" ]]; then
    echo "compose-doc-append-entry: language lint failed — WORKTREE_NOTES.md content does not match the configured language policy:" >&2
    LANG_VIOLATIONS="$LANG_VIOLATIONS" node -e '
        try {
            const v = JSON.parse(process.env.LANG_VIOLATIONS);
            v.forEach((x) => console.error("  [" + x.section + ":" + x.lineNumber + "] (expected " + (x.policy || "?") + ") " + x.line));
        } catch (e) {}
    ' 2>&1 || true
    if [[ "${DRY_RUN:-0}" -eq 1 ]]; then
        echo "compose-doc-append-entry: language violations detected (dry-run, continuing)" >&2
    else
        echo "compose-doc-append-entry: rewrite offending bullets to match the policy before re-running" >&2
        exit 1
    fi
fi

# --- Pre-flight: extract content and decide write targets (before gh API calls) ---
TODAY="$(date +%F)"

HISTORY_BULLETS="$(extract_section "History Notes")"
CHANGELOG_BULLETS="$(extract_section "Changelog Notes")"

# Fail-fast: when closes_issues is non-empty, History Notes MUST contain bullets.
# This is the canonical write path for docs/history.md (Approach C, #690) — empty
# History Notes means the user skipped /update-docs or wrote a placeholder.
if (( CLOSES_ISSUES_COUNT > 0 )) && [[ -z "$HISTORY_BULLETS" ]]; then
    echo "Error: closes_issues is non-empty but ## History Notes has no bullets. Run /update-docs first." >&2
    exit 1
fi

# Soft-warn: bullet count should match issue count (one history entry per closed issue).
if (( CLOSES_ISSUES_COUNT > 0 )); then
    HISTORY_BULLET_COUNT=$(printf '%s\n' "$HISTORY_BULLETS" | grep -c . || true)
    if (( HISTORY_BULLET_COUNT < CLOSES_ISSUES_COUNT )); then
        echo "Warning: closes_issues count ($CLOSES_ISSUES_COUNT) > history bullet count ($HISTORY_BULLET_COUNT). Expected one bullet per closed issue." >&2
    fi
fi

# Decide which targets are in play.
WANT_HISTORY=0
WANT_CHANGELOG=0
if [[ -n "$HISTORY_BULLETS" ]] && ! history_sentinel_found; then
    WANT_HISTORY=1
fi
if [[ -n "$CHANGELOG_BULLETS" ]] && ! changelog_marker_found; then
    WANT_CHANGELOG=1
fi
# --history / --changelog flags restrict processing to the named target.
if [[ "$HISTORY_ONLY" -eq 1 ]]; then
    WANT_CHANGELOG=0
fi
if [[ "$CHANGELOG_ONLY" -eq 1 ]]; then
    WANT_HISTORY=0
fi

# Nothing to write: exit early without any gh API calls.
if [[ "$WANT_HISTORY" -eq 0 ]] && [[ "$WANT_CHANGELOG" -eq 0 ]]; then
    exit 0
fi

# Dry-run: print intent summary and exit before gh API calls.
if [[ "$DRY_RUN" -eq 1 ]]; then
    [[ "$WANT_HISTORY" -eq 1 ]] && echo "[dry-run] would append to docs/history.md on default branch"
    [[ "$WANT_CHANGELOG" -eq 1 ]] && echo "[dry-run] would append to CHANGELOG.md on default branch"
    exit 0
fi

# --- Resolve owner/repo/default branch ---
if [[ -n "$REPO_OVERRIDE" ]]; then
    OWNER_REPO="$REPO_OVERRIDE"
elif ! OWNER_REPO=$(gh repo view --json owner,name --jq '.owner.login + "/" + .name' 2>/dev/null); then
    echo "compose-doc-append-entry: failed to resolve owner/repo via gh" >&2
    exit 1
fi
OWNER="${OWNER_REPO%%/*}"
REPO="${OWNER_REPO#*/}"
DEF=$(gh api "repos/$OWNER/$REPO" --jq '.default_branch' 2>/dev/null || echo "main")

# --- Fetch a file from GitHub into a local staging path ---
fetch_to_staging() {
    local remote_path="$1"
    local local_path="$2"
    local resp
    if resp=$(gh api "repos/$OWNER/$REPO/contents/$remote_path?ref=$DEF" 2>/dev/null); then
        printf '%s' "$resp" | jq -r '.content' | tr -d '\r\n' | base64 -d > "$local_path"
        return 0
    fi
    # File does not exist on remote — leave local file empty (caller decides).
    : > "$local_path"
    return 1
}

# --- Background derivation and staging paths ---
BG="$(derive_background)"
SESSION_ID="${CLAUDE_SESSION_ID:-$(date +%s)-$$}"
# SHORT_SHA is used by both WANT_HISTORY and WANT_CHANGELOG blocks; initialize early.
SHORT_SHA="${MERGE_COMMIT:0:7}"
if [[ "$BOOTSTRAP" -eq 1 ]]; then
    STAGE_TAG="bootstrap-${SHORT_SHA}"
else
    STAGE_TAG="pr${PR_NUMBER}"
fi
HISTORY_STAGING="${TARGET_HISTORY:-$STAGING_DIR/${SESSION_ID}-${STAGE_TAG}-history-staging.md}"
CHANGELOG_STAGING="${TARGET_CHANGELOG:-$STAGING_DIR/${SESSION_ID}-${STAGE_TAG}-changelog-staging.md}"

cleanup_staging() {
    [[ -f "${HISTORY_STAGING:-}" ]] && rm -f -- "$HISTORY_STAGING"
    [[ -f "${CHANGELOG_STAGING:-}" ]] && rm -f -- "$CHANGELOG_STAGING"
    if [[ -n "${ROTATE_DIR:-}" && -d "${ROTATE_DIR}" ]]; then
        local _sr _rr
        _sr="$(realpath "$STAGING_DIR" 2>/dev/null || printf '%s' "$STAGING_DIR")"
        _rr="$(realpath "$ROTATE_DIR"  2>/dev/null || printf '%s' "$ROTATE_DIR")"
        [[ "$_rr" == "$_sr/"* ]] && rm -rf -- "$ROTATE_DIR"
    fi
}
trap cleanup_staging EXIT HUP INT TERM

# --- Build the staged content for each target ---
if [[ "$WANT_HISTORY" -eq 1 ]]; then
    if ! fetch_to_staging "docs/history.md" "$HISTORY_STAGING"; then
        echo "compose-doc-append-entry: docs/history.md missing on remote; aborting history append" >&2
        exit 1
    fi
    if [[ "$BOOTSTRAP" -eq 1 ]]; then
        # Bootstrap history bullet: no (PR #N) suffix; use (bootstrap initial commit, <sha-short>).
        SENTINEL=" <!-- compose-doc-append-sentinel: branch=${BRANCH} bootstrap=${SHORT_SHA} -->"
        CHANGES_WITH_SENTINEL="$(echo "$HISTORY_BULLETS" | tr '\n' ';' | sed 's/;$//')${SENTINEL}"
        COMMITS_ARG="${MERGE_COMMIT}"
        SUBJECT="bootstrap initial commit — ${BRANCH} (${SHORT_SHA})"
    else
        SENTINEL=" <!-- compose-doc-append-sentinel: branch=${BRANCH} pr=#${PR_NUMBER} -->"
        CHANGES_WITH_SENTINEL="$(echo "$HISTORY_BULLETS" | tr '\n' ';' | sed 's/;$//')${SENTINEL}"
        if [[ -n "$MERGE_COMMIT" ]]; then
            COMMITS_ARG="${MERGE_COMMIT}, #${PR_NUMBER}"
        else
            COMMITS_ARG="#${PR_NUMBER}"
        fi
        SUBJECT="PR #${PR_NUMBER} — ${BRANCH}"
    fi

    if ! uv run "$SCRIPT_DIR/doc-append.py" "$HISTORY_STAGING" \
            --category "$CATEGORY" \
            --subject "$SUBJECT" \
            --date "$TODAY" \
            --commits "$COMMITS_ARG" \
            --background "$BG" \
            --changes "$CHANGES_WITH_SENTINEL" \
            ${TEST_GAP:+--test-gap "$TEST_GAP"}; then
        echo "compose-doc-append-entry: doc-append.py failed for history staging" >&2
        exit 1
    fi
    if [[ "$BOOTSTRAP" -eq 1 ]]; then
        HIST_COMMIT_SUBJECT="docs(history): record bootstrap initial commit ${SHORT_SHA}"
    else
        HIST_COMMIT_SUBJECT="docs(history): record PR #${PR_NUMBER}"
    fi
    if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-contents-validate.sh" \
            --path "docs/history.md" \
            --file "$HISTORY_STAGING" \
            --commit-subject "$HIST_COMMIT_SUBJECT"; then
        echo "compose-doc-append-entry: history validation failed" >&2
        exit 1
    fi
fi

if [[ "$WANT_CHANGELOG" -eq 1 ]]; then
    if ! fetch_to_staging "CHANGELOG.md" "$CHANGELOG_STAGING"; then
        echo "compose-doc-append-entry: CHANGELOG.md not present on remote, skipping changelog target" >&2
        WANT_CHANGELOG=0
    else
        CHANGES="$(echo "$CHANGELOG_BULLETS" | tr '\n' ';' | sed 's/;$//')"
        if [[ "$BOOTSTRAP" -eq 1 ]]; then
            SUBJ_CHANGELOG="bootstrap initial commit"
            CHLOG_COMMIT_SUBJECT="docs(changelog): record bootstrap initial commit ${SHORT_SHA}"
        else
            SUBJ_CHANGELOG="PR #${PR_NUMBER}"
            CHLOG_COMMIT_SUBJECT="docs(changelog): record PR #${PR_NUMBER}"
        fi

        if ! uv run "$SCRIPT_DIR/doc-append.py" "$CHANGELOG_STAGING" \
                --category "$CATEGORY" \
                --subject "$SUBJ_CHANGELOG" \
                --date "$TODAY" \
                --no-auto-rotate \
                --background "$BG" \
                --changes "$CHANGES"; then
            echo "compose-doc-append-entry: doc-append.py failed for changelog staging" >&2
            exit 1
        fi
        if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-contents-validate.sh" \
                --path "CHANGELOG.md" \
                --file "$CHANGELOG_STAGING" \
                --commit-subject "$CHLOG_COMMIT_SUBJECT"; then
            echo "compose-doc-append-entry: changelog validation failed" >&2
            exit 1
        fi
    fi
fi

# --- Write back to GitHub ---

# Determine if history requires rotation.
HISTORY_ROTATED=0
ROTATE_DIR=""
HISTORY_FILES_ARGS=()
if [[ "$WANT_HISTORY" -eq 1 ]]; then
    H_LINES=$(wc -l < "$HISTORY_STAGING")
    if (( H_LINES >= 500 )); then
        if ! uv run "$AGENTS_CONFIG_DIR/bin/doc-rotate.py" "$HISTORY_STAGING" --threshold-warn 500 >&2; then
            echo "compose-doc-append-entry: doc-rotate.py failed" >&2
            exit 1
        fi
        ROTATE_DIR="$(dirname "$HISTORY_STAGING")/history"
        HISTORY_ROTATED=1
        HISTORY_FILES_ARGS=(--file "docs/history.md=$HISTORY_STAGING")
        if [[ -d "$ROTATE_DIR" ]]; then
            for archive in "$ROTATE_DIR"/*.md; do
                [[ -f "$archive" ]] || continue
                BASENAME=$(basename "$archive")
                HISTORY_FILES_ARGS+=(--file "docs/history/$BASENAME=$archive")
            done
        fi
    fi
fi

# Decide write strategy:
#   - both targets, or history rotated → single atomic Git Data API commit
#   - one target only, no rotation     → Contents API single PUT
# Commit message labels: bootstrap mode uses the bootstrap SHA; normal mode uses PR #N.
if [[ "$BOOTSTRAP" -eq 1 ]]; then
    MSG_BOTH="docs: record bootstrap initial commit ${SHORT_SHA} (history + changelog)"
    MSG_HISTORY="docs(history): record bootstrap initial commit ${SHORT_SHA}"
    MSG_CHANGELOG="docs(changelog): record bootstrap initial commit ${SHORT_SHA}"
else
    MSG_BOTH="docs: record PR #${PR_NUMBER} (history + changelog)"
    MSG_HISTORY="docs(history): record PR #${PR_NUMBER}"
    MSG_CHANGELOG="docs(changelog): record PR #${PR_NUMBER}"
fi

if [[ "$WANT_HISTORY" -eq 1 ]] && [[ "$WANT_CHANGELOG" -eq 1 ]]; then
    # Atomic multi-file commit.
    FILES_ARGS=()
    if [[ "$HISTORY_ROTATED" -eq 1 ]]; then
        FILES_ARGS=("${HISTORY_FILES_ARGS[@]}")
    else
        FILES_ARGS=(--file "docs/history.md=$HISTORY_STAGING")
    fi
    FILES_ARGS+=(--file "CHANGELOG.md=$CHANGELOG_STAGING")
    if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-git-data-write.sh" \
            --owner "$OWNER" --repo "$REPO" --branch "$DEF" \
            --message "$MSG_BOTH" \
            "${FILES_ARGS[@]}"; then
        echo "compose-doc-append-entry: atomic multi-file write failed" >&2
        exit 1
    fi
    write_history_marker
    write_changelog_marker
elif [[ "$WANT_HISTORY" -eq 1 ]]; then
    if [[ "$HISTORY_ROTATED" -eq 1 ]]; then
        if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-git-data-write.sh" \
                --owner "$OWNER" --repo "$REPO" --branch "$DEF" \
                --message "$MSG_HISTORY" \
                "${HISTORY_FILES_ARGS[@]}"; then
            echo "compose-doc-append-entry: history rotation write failed" >&2
            exit 1
        fi
    else
        if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-contents-write.sh" \
                --owner "$OWNER" --repo "$REPO" \
                --path "docs/history.md" \
                --file "$HISTORY_STAGING" \
                --message "$MSG_HISTORY" \
                --branch "$DEF"; then
            echo "compose-doc-append-entry: history single-file write failed" >&2
            exit 1
        fi
    fi
    write_history_marker
elif [[ "$WANT_CHANGELOG" -eq 1 ]]; then
    if ! bash "$AGENTS_CONFIG_DIR/bin/lib/github-contents-write.sh" \
            --owner "$OWNER" --repo "$REPO" \
            --path "CHANGELOG.md" \
            --file "$CHANGELOG_STAGING" \
            --message "$MSG_CHANGELOG" \
            --branch "$DEF"; then
        echo "compose-doc-append-entry: changelog single-file write failed" >&2
        exit 1
    fi
    write_changelog_marker
fi

# --- Cleanup staging files ---
[[ -f "$HISTORY_STAGING" ]] && rm -f "$HISTORY_STAGING"
[[ -f "$CHANGELOG_STAGING" ]] && rm -f "$CHANGELOG_STAGING"
[[ -n "$ROTATE_DIR" ]] && [[ -d "$ROTATE_DIR" ]] && rm -rf "$ROTATE_DIR"

exit 0
