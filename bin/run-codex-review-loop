#!/usr/bin/env bash
# bin/run-codex-review-loop
# Wrapper that enforces step b (context build) + step c (review-plan-codex)
# + step d (verdict parse) of skills/_shared/codex-review-loop.md.
#
# Exit codes (see skills/_shared/codex-review-loop.md for SSOT table):
#   0 — APPROVED
#   1 — NON_APPROVED_VERDICT (NEEDS_REVISION / MISSING_ALTERNATIVE:)
#   2 — FAILED — round cap reached
#   3 — codex CLI unusable (SKIPPED / FAILED-other / verdict malformed)
#       -> caller silently falls back to REVIEWER_AGENT subagent
#   4 — wrapper / config / parser failure (unset AGENTS_CONFIG_DIR,
#       missing core-principles.md, missing arg, missing option value,
#       missing binaries, unrecognized status header, etc.)
#       -> caller MUST halt with blocking error; do NOT fall back.
set -uo pipefail

die() {
  echo "run-codex-review-loop: script error: $1" >&2
  exit 4
}

require_value() {
  local flag="$1"
  local val="${2-__MISSING__}"
  [[ "$val" != "__MISSING__" && -n "$val" ]] || die "$flag requires a value"
  [[ "$val" != --* ]] || die "$flag requires a value (got flag-like token: $val)"
}

# --- Pre-flight: AGENTS_CONFIG_DIR and core-principles.md ---
[[ -n "${AGENTS_CONFIG_DIR:-}" ]] || die "AGENTS_CONFIG_DIR is not set"
[[ -d "$AGENTS_CONFIG_DIR" ]]      || die "AGENTS_CONFIG_DIR does not exist: $AGENTS_CONFIG_DIR"
CORE_PRINCIPLES="$AGENTS_CONFIG_DIR/rules/core-principles.md"
[[ -f "$CORE_PRINCIPLES" ]] || die "required context missing: $CORE_PRINCIPLES"

FORMAT=""
SID=""
PLANS_DIR=""
DRAFT=""
CAP=""
MAX_EXT=""
EXT_USED="0"
TRADEOFFS=""
ROUND=""
LEDGER_OVERRIDE=""
EXTRA_CTX=()
REPO_ROOT_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --format)
      require_value "--format" "${2:-}"
      FORMAT="$2"; shift 2 ;;
    --session-id)
      require_value "--session-id" "${2:-}"
      SID="$2"; shift 2 ;;
    --plans-dir)
      require_value "--plans-dir" "${2:-}"
      PLANS_DIR="$2"; shift 2 ;;
    # Note: --draft-file is the path the planner wrote to (now the in-place final-artifact path).
    --draft-file)
      require_value "--draft-file" "${2:-}"
      DRAFT="$2"; shift 2 ;;
    --cap)
      require_value "--cap" "${2:-}"
      CAP="$2"; shift 2 ;;
    --max-extensions)
      require_value "--max-extensions" "${2:-}"
      MAX_EXT="$2"; shift 2 ;;
    --extensions-used)
      require_value "--extensions-used" "${2:-}"
      EXT_USED="$2"; shift 2 ;;
    --accepted-tradeoffs)
      require_value "--accepted-tradeoffs" "${2:-}"
      TRADEOFFS="$2"; shift 2 ;;
    --round)
      require_value "--round" "${2:-}"
      ROUND="$2"; shift 2 ;;
    --ledger)
      require_value "--ledger" "${2:-}"
      LEDGER_OVERRIDE="$2"; shift 2 ;;
    --context)
      require_value "--context" "${2:-}"
      EXTRA_CTX+=("$2"); shift 2 ;;
    --repo-root)
      require_value "--repo-root" "${2:-}"
      REPO_ROOT_ARG="$2"; shift 2 ;;
    *) die "unknown argument: $1" ;;
  esac
done

[[ -n "$FORMAT" ]]    || die "--format is required"
[[ -n "$SID" ]]       || die "--session-id is required"
[[ -n "$PLANS_DIR" ]] || die "--plans-dir is required"
[[ -n "$DRAFT" ]]     || die "--draft-file is required"
[[ -n "$CAP" ]]       || die "--cap is required"
[[ -n "$MAX_EXT" ]]   || die "--max-extensions is required"
[[ -n "$TRADEOFFS" ]] || die "--accepted-tradeoffs is required"
[[ -n "$ROUND" ]] || { echo "run-codex-review-loop: --round is required" >&2; exit 4; }
[[ "$ROUND" =~ ^[1-9][0-9]*$ ]] || { echo "run-codex-review-loop: --round must be a positive integer" >&2; exit 4; }

case "$FORMAT" in
  detail-plan|outline-plan) ;;
  *) die "--format must be detail-plan or outline-plan" ;;
esac

[[ -f "$DRAFT" ]]     || die "draft file does not exist: $DRAFT"
[[ -d "$PLANS_DIR" ]] || die "plans dir does not exist: $PLANS_DIR"

if [[ -z "$REPO_ROOT_ARG" ]]; then
  REPO_ROOT_ARG="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi

if [[ -n "$REPO_ROOT_ARG" ]] && [[ ! -d "$REPO_ROOT_ARG" ]]; then
  die "--repo-root is not a directory: $REPO_ROOT_ARG"
fi

BUILDER="$AGENTS_CONFIG_DIR/bin/build-codex-context"
REVIEWER="$AGENTS_CONFIG_DIR/bin/review-plan-codex"
[[ -f "$BUILDER" ]]  || die "build-codex-context not found: $BUILDER"
[[ -f "$REVIEWER" ]] || die "review-plan-codex not found: $REVIEWER"

mkdir -p "$PLANS_DIR" || die "cannot create PLANS_DIR: $PLANS_DIR"

CONTEXT_OUT="$PLANS_DIR/$SID-codex-context.md"
MARKER="$PLANS_DIR/$SID-codex-context.$FORMAT.built"
if [[ -n "$LEDGER_OVERRIDE" ]]; then
  LEDGER="$LEDGER_OVERRIDE"
else
  LEDGER="$PLANS_DIR/$SID-$FORMAT-concern-ledger.txt"
fi

if [[ ! -f "$MARKER" ]]; then
  if ! bash "$BUILDER" --plans-dir "$PLANS_DIR" --session-id "$SID" --output "$CONTEXT_OUT"; then
    die "build-codex-context failed"
  fi
  : > "$MARKER" || die "cannot create marker: $MARKER"
fi

ARGS=(
  --input "$DRAFT"
  --format "$FORMAT"
  --session-id "$SID"
  --log-dir "$PLANS_DIR"
  --cap "$CAP"
  --max-extensions "$MAX_EXT"
  --extensions-used "$EXT_USED"
  --accepted-tradeoffs "$TRADEOFFS"
  --round "$ROUND"
)

if [[ "$ROUND" -ge 2 ]]; then
  if [[ -f "$LEDGER" ]]; then
    ARGS+=(--ledger "$LEDGER")
  elif [[ -z "$LEDGER_OVERRIDE" ]]; then
    echo "run-codex-review-loop: ledger absent at round ${ROUND} — downgrading effective round to 1 (concern-ID continuity lost; see #748/#776)" >&2
    ROUND=1
    for i in "${!ARGS[@]}"; do
      if [[ "${ARGS[$i]}" == "--round" ]]; then
        ARGS[$((i+1))]="1"
        break
      fi
    done
  fi
fi

if [[ -f "$CONTEXT_OUT" && -s "$CONTEXT_OUT" ]]; then
  ARGS+=(--context "$CONTEXT_OUT")
fi

for ctx in "${EXTRA_CTX[@]+"${EXTRA_CTX[@]}"}"; do
  [[ -z "$ctx" ]] && continue
  if [[ -f "$ctx" && -s "$ctx" ]]; then
    ARGS+=(--context "$ctx")
  fi
done

ARGS+=(--context "$CORE_PRINCIPLES")

if [[ "${CODEX_MCP_FS:-}" != "off" ]] && [[ -n "$REPO_ROOT_ARG" ]]; then
  ARGS+=(--repo-root "$REPO_ROOT_ARG")
fi

TMP_OUT=$(mktemp) || die "mktemp failed"
trap 'rm -f "$TMP_OUT"' EXIT

bash "$REVIEWER" "${ARGS[@]}" > "$TMP_OUT"
RV=$?

if [[ $RV -ne 0 ]]; then
  echo "run-codex-review-loop: codex unavailable (review-plan-codex exited $RV)" >&2
  exit 3
fi

HEADER=$(awk 'NF{print; exit}' "$TMP_OUT" | tr -d '\r')

case "$HEADER" in
  "## Codex Plan Review: PERFORMED")
    : ;;
  "## Codex Plan Review: FAILED — round cap reached"*)
    echo "run-codex-review-loop: round cap reached" >&2
    exit 2 ;;
  "## Codex Plan Review: SKIPPED"*)
    echo "run-codex-review-loop: codex unavailable or verdict malformed (header=$HEADER)" >&2
    exit 3 ;;
  "## Codex Plan Review: FAILED"*)
    echo "run-codex-review-loop: codex unavailable or verdict malformed (header=$HEADER)" >&2
    exit 3 ;;
  *)
    die "unrecognized status header: $HEADER" ;;
esac

VERDICT=$(awk '
  /<!-- begin-codex-output/ { inblock=1; next }
  /<!-- end-codex-output -->/ { inblock=0; next }
  inblock && NF { print; exit }
' "$TMP_OUT" | tr -d '\r')

if [[ -z "$VERDICT" ]]; then
  echo "run-codex-review-loop: codex unavailable or verdict malformed (empty verdict block)" >&2
  exit 3
fi

# Validate verdict matches expected non-APPROVED keyword for the format
if [[ ! "$VERDICT" =~ ^APPROVED($|[[:space:]].+$) ]]; then
  case "$FORMAT" in
    detail-plan)
      [[ "$VERDICT" == "NEEDS_REVISION" ]] || {
        echo "run-codex-review-loop: codex unavailable or verdict malformed (header=$HEADER, verdict=$VERDICT)" >&2
        exit 3
      } ;;
    outline-plan)
      [[ "$VERDICT" =~ ^MISSING_ALTERNATIVE: ]] || {
        echo "run-codex-review-loop: codex unavailable or verdict malformed (header=$HEADER, verdict=$VERDICT)" >&2
        exit 3
      } ;;
  esac
fi

# --- BEGIN concern-ID ledger + verdict-script block (issue #673) ---
FINAL_EXIT=0
HIGH_N=0; MED_N=0; LOW_N=0

if [[ ! "$VERDICT" =~ ^APPROVED($|[[:space:]]) ]]; then
  if [[ "$ROUND" == "1" ]]; then
    # Round 1: parse concerns, assign Cn IDs, build ledger.
    LEDGER_CONTENT=""
    ID_COUNTER=0
    TRANSFORMED_CONTENT=""
    INBLOCK=0

    while IFS= read -r line; do
      if [[ "$line" =~ ^\<!--[[:space:]]*begin-codex-output ]]; then
        INBLOCK=1
        TRANSFORMED_CONTENT+="$line"$'\n'
        continue
      fi
      if [[ "$line" =~ ^\<!--[[:space:]]*end-codex-output ]]; then
        INBLOCK=0
        TRANSFORMED_CONTENT+="$line"$'\n'
        continue
      fi
      if [[ "$INBLOCK" -eq 1 ]] && \
         [[ "$line" =~ ^(C[0-9]+|[0-9]+)\.[[:space:]]\[(HIGH|MEDIUM|LOW)\][[:space:]](.+)$ ]]; then
        SEV="${BASH_REMATCH[2]}"
        TEXT="${BASH_REMATCH[3]}"
        ID_COUNTER=$((ID_COUNTER + 1))
        CN="C${ID_COUNTER}"
        LEDGER_CONTENT+="${CN}|${SEV}|${TEXT}"$'\n'
        TRANSFORMED_CONTENT+="${CN}. [${SEV}] ${TEXT}"$'\n'
        case "$SEV" in
          HIGH)   HIGH_N=$((HIGH_N + 1)) ;;
          MEDIUM) MED_N=$((MED_N + 1)) ;;
          LOW)    LOW_N=$((LOW_N + 1)) ;;
        esac
      elif [[ "$INBLOCK" -eq 1 ]] && [[ "$line" =~ ^[0-9]+\.[[:space:]] ]]; then
        # Numbered line that did not match the full [HIGH|MEDIUM|LOW] format — format violation.
        echo "run-codex-review-loop: severity format violation in concern: $line" >&2
        exit 4
      else
        TRANSFORMED_CONTENT+="$line"$'\n'
      fi
    done < "$TMP_OUT"

    if [[ $ID_COUNTER -eq 0 ]]; then
      echo "run-codex-review-loop: NEEDS_REVISION with no parseable concerns" >&2
      exit 4
    fi

    LEDGER_TMP="${LEDGER}.tmp.$$"
    if ! printf '%s' "$LEDGER_CONTENT" > "$LEDGER_TMP"; then
      echo "run-codex-review-loop: failed to write ledger to $LEDGER" >&2
      rm -f "$LEDGER_TMP"
      exit 4
    fi
    mv "$LEDGER_TMP" "$LEDGER"

    printf '%s' "$TRANSFORMED_CONTENT" > "$TMP_OUT"

  else
    # Round 2+: validate against ledger.
    [[ -f "$LEDGER" ]] || {
      echo "run-codex-review-loop: ledger missing for round ${ROUND} (expected at ${LEDGER})" >&2
      exit 4
    }

    declare -A LEDGER_IDS
    while IFS='|' read -r LID LSEV _; do
      [[ -n "$LID" ]] || continue
      LEDGER_IDS["$LID"]="$LSEV"
    done < "$LEDGER"

    DISCARDED=()
    RETAINED_CONTENT=""
    INBLOCK=0

    while IFS= read -r line; do
      if [[ "$line" =~ ^\<!--[[:space:]]*begin-codex-output ]]; then
        INBLOCK=1
        RETAINED_CONTENT+="$line"$'\n'
        continue
      fi
      if [[ "$line" =~ ^\<!--[[:space:]]*end-codex-output ]]; then
        INBLOCK=0
        RETAINED_CONTENT+="$line"$'\n'
        continue
      fi
      if [[ "$INBLOCK" -eq 1 ]] && [[ "$line" =~ ^(C[0-9]+):[[:space:]]*(.*)$ ]]; then
        CID="${BASH_REMATCH[1]}"
        STATUS="${BASH_REMATCH[2]}"
        if [[ -v LEDGER_IDS["$CID"] ]]; then
          RETAINED_CONTENT+="$line"$'\n'
          # Tally as unresolved unless the disposition starts with "resolved"
          if [[ ! "$STATUS" =~ ^resolved($|[[:space:]]) ]]; then
            case "${LEDGER_IDS[$CID]}" in
              HIGH)   HIGH_N=$((HIGH_N + 1)) ;;
              MEDIUM) MED_N=$((MED_N + 1)) ;;
              LOW)    LOW_N=$((LOW_N + 1)) ;;
            esac
          fi
        else
          DISCARDED+=("$CID")
        fi
      else
        RETAINED_CONTENT+="$line"$'\n'
      fi
    done < "$TMP_OUT"

    if (( ${#DISCARDED[@]} > 0 )); then
      DISCARDED_STR=$(printf '%s\n' "${DISCARDED[@]}" | sort -V | paste -sd ',' - | sed 's/,/, /g')
      printf 'run-codex-review-loop: discarded new concern IDs in round %s: %s\n' \
        "$ROUND" "$DISCARDED_STR" >&2
    fi

    printf '%s' "$RETAINED_CONTENT" > "$TMP_OUT"
  fi

  VERDICT_BIN="${AGENTS_CONFIG_DIR}/bin/review-loop-verdict"
  [[ -x "$VERDICT_BIN" ]] || {
    echo "run-codex-review-loop: review-loop-verdict not found or not executable: $VERDICT_BIN" >&2
    exit 4
  }
  VERDICT_DECISION=$("$VERDICT_BIN" "$ROUND" "$HIGH_N" "$MED_N" "$LOW_N")
  VERDICT_RC=$?
  : "${VERDICT_DECISION:=}"

  case "$VERDICT_RC" in
    0)
      rm -f "$LEDGER"
      FINAL_EXIT=0
      ;;
    1)
      FINAL_EXIT=1
      ;;
    2)
      cp "$LEDGER" "${LEDGER%.txt}-cap-snapshot.txt" 2>/dev/null || true
      rm -f "$LEDGER"
      FINAL_EXIT=2
      ;;
    3)
      echo "run-codex-review-loop: review-loop-verdict argument error (round=$ROUND high=$HIGH_N med=$MED_N low=$LOW_N)" >&2
      exit 4
      ;;
    *)
      echo "run-codex-review-loop: review-loop-verdict unexpected exit: $VERDICT_RC" >&2
      exit 4
      ;;
  esac
else
  rm -f "$LEDGER"
  FINAL_EXIT=0
fi
# --- END concern-ID ledger + verdict-script block ---

cat "$TMP_OUT"
exit "$FINAL_EXIT"
